                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0111161/img" class="w-full h-full object-cover"></div>
                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0109830/img" class="w-full h-full object-cover"></div>
