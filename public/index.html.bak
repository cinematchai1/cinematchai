                footerLegalTitle: "Legal",
                footerPlatformTitle: "Plataforma",
                footerTerms: "Termos de Serviço",
                footerPrivacy: "Política de Privacidade",
                footerDmca: "Aviso de Direitos (DMCA)",
                footerFaq: "Perguntas Frequentes (FAQ)",
                footerContact: "Contactar Suporte",
                footerDonate: "Apoiar Projeto 💖",
                footerDesc: "O teu assistente pessoal de cinema impulsionado por Inteligência Artificial. Descobre o teu próximo filme favorito.",
                
                termsTitle: "Termos de Serviço",
                termsContent: "<h4>1. Natureza do Serviço</h4><p class='mb-4'>O CineMatch AI é uma plataforma de recomendação de filmes baseada em Inteligência Artificial. Não alojamos, transmitimos ou distribuímos filmes completos.</p><h4>2. Isenção de Responsabilidade (IA)</h4><p class='mb-4'>As recomendações são geradas por algoritmos externos (Google Gemini). Não nos responsabilizamos por respostas imprecisas, ofensivas ou incorretas geradas pela IA.</p><h4>3. Limite de Idade</h4><p class='mb-4'>A plataforma destina-se a utilizadores com 16 anos ou mais. A IA pode gerar recomendações de filmes para adultos (Rated R).</p><h4>4. Utilização e Suspensão</h4><p class='mb-4'>O utilizador concorda em usar a plataforma de forma lícita. Reservamo-nos o direito de suspender contas a qualquer momento, sem aviso prévio, por abuso ou segurança.</p><h4>5. Limitação de Responsabilidade</h4><p>O serviço é fornecido \"tal como está\". Não garantimos 100% de disponibilidade dos servidores nem assumimos responsabilidade por perda de dados, interrupções ou erros.</p>",
                
                privacyTitle: "Política de Privacidade",
                privacyContent: "<h4>1. Recolha de Dados</h4><p class='mb-4'>Apenas recolhemos as informações essenciais para o funcionamento da tua conta (Nome de Utilizador/Email e Password encriptada). Não monitorizamos a tua navegação fora da plataforma.</p><h4>2. Segurança dos Dados</h4><p class='mb-4'>As tuas passwords são guardadas usando encriptação (Bcrypt). Nós não temos acesso à tua password real.</p><h4>3. Partilha de Dados</h4><p class='mb-4'>O CineMatch AI <b>não vende</b> os teus dados a terceiros, empresas de marketing ou anunciantes.</p><h4>4. Eliminação de Conta</h4><p>Podes solicitar a eliminação total dos teus dados e histórico contactando o nosso suporte.</p>",
                
                dmcaTitle: "Aviso de Direitos (DMCA)",
                dmcaContent: "<h4>Aviso de Direitos de Autor e Proteção de Propriedade Intelectual</h4><p class='mb-4'>O CineMatch AI é <b>estritamente um serviço de recomendação e catalogação</b>. O nosso servidor <b>não aloja, não faz upload e não transmite</b> ficheiros de vídeo, filmes, séries ou material protegido por direitos de autor.</p><h4>Origem dos Dados</h4><p class='mb-4'>As imagens (posters), sinopses e metadados exibidos nesta plataforma são obtidos através de bases de dados públicas e APIs de terceiros (como o TMDB - The Movie Database). Estes conteúdos são propriedade intelectual dos respetivos estúdios e produtoras de cinema. O CineMatch AI utiliza-os ao abrigo do princípio de <i>Fair Use</i> (Uso Justo) estritamente para fins informativos e de recomendação.</p><h4>Remoção de Conteúdo (DMCA)</h4><p>Se és o detentor dos direitos de autor de qualquer conteúdo exibido incorretamente e desejas que seja removido do nosso catálogo visual, por favor envia um email para info@cinematchai.com e removeremos as referências de imediato.</p>",
                
                faqTitle: "Perguntas Frequentes (FAQ)",
                faqContent: "<details class='mb-2 bg-slate-800 rounded p-3 cursor-pointer group'><summary class='font-semibold text-white group-hover:text-sky-400'>O CineMatch AI é gratuito?</summary><p class='mt-2 text-slate-400 text-sm'>Sim! O uso básico da plataforma é 100% gratuito. Dependemos de doações para manter os servidores online.</p></details><details class='mb-2 bg-slate-800 rounded p-3 cursor-pointer group'><summary class='font-semibold text-white group-hover:text-sky-400'>Posso ver filmes aqui?</summary><p class='mt-2 text-slate-400 text-sm'>Não. O CineMatch AI é uma ferramenta para descobrir filmes novos. Não somos uma plataforma de streaming.</p></details><details class='mb-2 bg-slate-800 rounded p-3 cursor-pointer group'><summary class='font-semibold text-white group-hover:text-sky-400'>Como funciona a IA?</summary><p class='mt-2 text-slate-400 text-sm'>Usamos o Google Gemini. O nosso sistema analisa o teu pedido e o teu histórico para instruir a IA a encontrar os filmes perfeitos para o teu gosto.</p></details>",
                
                cookieText: "O CineMatch AI utiliza armazenamento local para guardar as tuas preferências e manter a tua sessão ativa. Ao continuares a utilizar o site, concordas com a nossa Política de Privacidade.",
                cookieBtn: "Compreendi"
            }
        };

        // State
        let isLoggedIn = false;
        let currentUser = '';
        let currentDisplayName = '';
        let currentUserAvatar = '';
        let isLoginMode = true;
        let userWatchlist = [];
        let isPublicShareMode = false;
        let activeTab = 'home'; // 'home' or 'watchlist'
        
        let currentLang = localStorage.getItem('cinematch_lang');
        if (!currentLang) {
            currentLang = navigator.language.toLowerCase().startsWith('pt') ? 'pt' : 'en';
        }

        let lastSearchedMovie = '';
        let lastMovieData = null; // Store data to re-render without re-fetching

        // YouTube Player API State & Dynamic Script Insertion
        let ytPlayer = null;
        const tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        const firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        // Generic page section transition animation helper
        function transitionTo(hideIds, showIds, callback) {
            const hideElems = hideIds.map(id => document.getElementById(id)).filter(Boolean);
            const showElems = showIds.map(id => document.getElementById(id)).filter(Boolean);
            
            // Add page-transition and exit class
            hideElems.forEach(el => {
                el.classList.add('page-transition');
                el.classList.add('page-exit');
            });
            
            // Trigger exit transition
            setTimeout(() => {
                hideElems.forEach(el => {
                    el.classList.add('page-exit-active');
                });
            }, 10);
            
            // Switch sections after exit animation finishes
            setTimeout(() => {
                hideElems.forEach(el => {
                    el.classList.add('hidden-section');
                    el.classList.remove('page-transition', 'page-exit', 'page-exit-active');
                });
                
                if (callback) callback();
                
                showElems.forEach(el => {
                    el.classList.remove('hidden-section');
                    el.classList.add('page-transition', 'page-enter');
                });
                
                // Force layout reflow
                showElems.forEach(el => el.offsetHeight);
                
                // Trigger enter transition
                showElems.forEach(el => {
                    el.classList.add('page-enter-active');
                });
                
                // Clean up transition classes
                setTimeout(() => {
                    showElems.forEach(el => {
                        el.classList.remove('page-transition', 'page-enter', 'page-enter-active');
                    });
                }, 400);
                
            }, 350);
        }

        // Elements
        const currentLangDisplay = document.getElementById('current-lang-display');
        const langOptions = document.querySelectorAll('.lang-option');
        const navActions = document.getElementById('nav-actions');
        const heroHeader = document.getElementById('hero-header');
        const searchContainer = document.getElementById('search-container');
        const featuresSection = document.getElementById('features-section');
        const resultsContainer = document.getElementById('results-container');
        const referenceMovieContainer = document.getElementById('reference-movie-container');
        
        const authModal = document.getElementById('auth-modal');
        const closeModalBtn = document.getElementById('close-modal');
        const tabLogin = document.getElementById('tab-login');
        const tabRegister = document.getElementById('tab-register');
        const loginForm = document.getElementById('login-form');
        const registerForm = document.getElementById('register-form');
        const loginUser = document.getElementById('login-user');
        const loginPass = document.getElementById('login-pass');
        const registerUser = document.getElementById('register-user');
        const registerPass = document.getElementById('register-pass');
        const loginBtnText = document.getElementById('login-btn-text');
        const registerBtnText = document.getElementById('register-btn-text');
        const authError = document.getElementById('auth-error');

        const searchForm = document.getElementById('search-form');
        const movieInput = document.getElementById('movie-input');
        
        // Autocomplete Logic
        const autocompleteDropdown = document.getElementById('autocomplete-dropdown');
        const autocompleteList = document.getElementById('autocomplete-list');
        let autocompleteTimer;

        movieInput.addEventListener('input', (e) => {
            const query = e.target.value.trim();
            clearTimeout(autocompleteTimer);
            
            if (query.length < 3) {
                autocompleteDropdown.classList.add('hidden');
                return;
            }

            autocompleteTimer = setTimeout(async () => {
                try {
                    const [resMovies, resSeries] = await Promise.all([
                        fetch(`/api/proxy/catalog/movie/search=${encodeURIComponent(query)}`).catch(() => null),
                        fetch(`/api/proxy/catalog/series/search=${encodeURIComponent(query)}`).catch(() => null)
                    ]);
                    
                    let metas = [];
                    if (resMovies && resMovies.ok) {
                        const dataM = await resMovies.json();
                        if (dataM.metas) metas = metas.concat(dataM.metas);
                    }
                    if (resSeries && resSeries.ok) {
                        const dataS = await resSeries.json();
                        if (dataS.metas) metas = metas.concat(dataS.metas);
                    }

                    if (metas.length > 0) {
                        const seen = new Set();
                        metas = metas.filter(m => {
                            if (!m || !m.id || seen.has(m.id)) return false;
                            seen.add(m.id);
                            return true;
                        });
                        
                        metas.sort((a, b) => (b.popularity || 0) - (a.popularity || 0));

                        autocompleteList.innerHTML = '';
                        metas.slice(0, 6).forEach(meta => {
                            const li = document.createElement('li');
                            li.className = 'px-4 py-3 hover:bg-slate-800 cursor-pointer flex items-center gap-3 transition-colors border-b border-slate-800/50 last:border-0';
                            
                            const imgHtml = meta.poster 
                                ? `<img loading=" lazy\ decoding=\async\ src="${meta.poster}" class="w-10 h-14 object-cover rounded shadow-sm flex-shrink-0" onerror="this.src='https://via.placeholder.com/40x56/0f1115/ffffff?text=?'">` 
                                : `<div class="w-10 h-14 bg-slate-800 rounded flex items-center justify-center text-slate-500 flex-shrink-0"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 4v16M17 4v16M3 8h4m10 0h4M3 12h18M3 16h4m10 0h4M4 20h16a1 1 0 001-1V5a1 1 0 00-1-1H4a1 1 0 00-1 1v14a1 1 0 001 1z"></path></svg></div>`;
                                
                            const typeLabel = meta.type === 'series' ? (currentLang === 'pt' ? 'Série' : 'Series') : (currentLang === 'pt' ? 'Filme' : 'Movie');
                            
                            li.innerHTML = `
                                ${imgHtml}
                                <div class="flex flex-col overflow-hidden">
                                    <span class="text-white font-medium truncate">${meta.name}</span>
                                    <span class="text-xs text-slate-400">${meta.releaseInfo || ''} &bull; ${typeLabel}</span>
                                </div>
                            `;
                            
                            li.addEventListener('click', () => {
                                movieInput.value = meta.name;
                                autocompleteDropdown.classList.add('hidden');
                                searchForm.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
                            });
                            
                            autocompleteList.appendChild(li);
                        });
                        autocompleteDropdown.classList.remove('hidden');
                    } else {
                        autocompleteDropdown.classList.add('hidden');
                    }
                } catch (err) {
                    console.error('Autocomplete error:', err);
                }
            }, 300);
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', (e) => {
            if (!movieInput.contains(e.target) && !autocompleteDropdown.contains(e.target)) {
                autocompleteDropdown.classList.add('hidden');
            }
        });

        movieInput.addEventListener('keydown', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                autocompleteDropdown.classList.add('hidden');
                searchForm.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
            }
        });

        const btnText = document.getElementById('btn-text');
        const btnLoader = document.getElementById('btn-loader');
        const errorMsg = document.getElementById('error-message');
        const searchBtn = searchForm.querySelector('button[type="submit"]');

        // Apply Translations
        function updateUI() {
            const t = dict[currentLang];
            currentLangDisplay.textContent = currentLang === 'en' ? 'ENG' : 'PT';
            document.getElementById('current-lang-flag').src = currentLang === 'en' ? 'https://flagcdn.com/w20/gb.png' : 'https://flagcdn.com/w20/pt.png';
            
            document.getElementById('hero-title').textContent = t.heroTitle;
            document.getElementById('hero-subtitle').textContent = t.heroSub;
            movieInput.placeholder = t.inputPlaceholder;
            btnText.textContent = t.btnDiscover;
            
            document.getElementById('feat1-title').textContent = t.feat1Title;
            document.getElementById('feat1-desc').textContent = t.feat1Desc;
            document.getElementById('feat2-title').textContent = t.feat2Title;
            document.getElementById('feat2-desc').textContent = t.feat2Desc;
            document.getElementById('feat3-title').textContent = t.feat3Title;
            document.getElementById('feat3-desc').textContent = t.feat3Desc;
            
            if (window.navProfileLink) window.navProfileLink.textContent = t.navProfile;
            document.getElementById('modal-title').textContent = t.modalJoin;
            document.getElementById('modal-subtitle').textContent = t.modalSub;
            
            if (document.getElementById('nav-support-text')) document.getElementById('nav-support-text').textContent = t.navSupport;
            if (document.getElementById('support-title')) document.getElementById('support-title').textContent = t.supportTitle;
            if (document.getElementById('support-desc')) document.getElementById('support-desc').textContent = t.supportDesc;
            if (document.getElementById('support-leaderboard-title')) document.getElementById('support-leaderboard-title').textContent = t.supportLeaderboard;
            if (document.getElementById('support-btn-paypal')) document.getElementById('support-btn-paypal').textContent = t.supportBtnPaypal;
            if (document.getElementById('support-btn-revolut')) document.getElementById('support-btn-revolut').textContent = t.supportBtnRevolut;
            document.getElementById('footer-contact').textContent = t.footerContact;
            
            // Auth modals
            const fpLink = document.getElementById('forgot-password-link');
            if(fpLink) fpLink.textContent = t.forgotPasswordLink;
            const fpTitle = document.getElementById('forgot-password-title');
            if(fpTitle) fpTitle.textContent = t.forgotPasswordTitle;
            const fpDesc = document.getElementById('forgot-password-desc');
            if(fpDesc) fpDesc.textContent = t.forgotPasswordDesc;
            const fpBtnText = document.getElementById('forgot-password-btn-text');
            if(fpBtnText) fpBtnText.textContent = t.forgotPasswordBtn;
            
            // Footer Elements
            if(document.getElementById('footer-desc')) document.getElementById('footer-desc').textContent = t.footerDesc;
            if(document.getElementById('footer-legal-title')) document.getElementById('footer-legal-title').textContent = t.footerLegalTitle;
            if(document.getElementById('footer-platform-title')) document.getElementById('footer-platform-title').textContent = t.footerPlatformTitle;
            if(document.getElementById('footer-terms')) document.getElementById('footer-terms').textContent = t.footerTerms;
            if(document.getElementById('footer-privacy')) document.getElementById('footer-privacy').textContent = t.footerPrivacy;
            if(document.getElementById('footer-dmca')) document.getElementById('footer-dmca').textContent = t.footerDmca;
            if(document.getElementById('footer-faq')) document.getElementById('footer-faq').textContent = t.footerFaq;
            if(document.getElementById('footer-contact')) document.getElementById('footer-contact').textContent = t.footerContact;
            if(document.getElementById('footer-donate')) document.getElementById('footer-donate').textContent = t.footerDonate;
            
            // Modals Content
            if(document.getElementById('terms-title')) document.getElementById('terms-title').textContent = t.termsTitle;
            if(document.getElementById('terms-content')) document.getElementById('terms-content').innerHTML = t.termsContent;
            
            if(document.getElementById('privacy-title')) document.getElementById('privacy-title').textContent = t.privacyTitle;
            if(document.getElementById('privacy-content')) document.getElementById('privacy-content').innerHTML = t.privacyContent;
            
            if(document.getElementById('dmca-title')) document.getElementById('dmca-title').textContent = t.dmcaTitle;
            if(document.getElementById('dmca-content')) document.getElementById('dmca-content').innerHTML = t.dmcaContent;
            
            if(document.getElementById('faq-title')) document.getElementById('faq-title').textContent = t.faqTitle;
            if(document.getElementById('faq-content')) document.getElementById('faq-content').innerHTML = t.faqContent;
            
            // Cookie Banner
            if(document.getElementById('cookie-text')) document.getElementById('cookie-text').textContent = t.cookieText;
            if(document.getElementById('cookie-btn')) document.getElementById('cookie-btn').textContent = t.cookieBtn;
            
            // Watchlist tab
            const watchlistTab = document.getElementById('tab-watchlist');
            
            if (document.getElementById('contact-title')) document.getElementById('contact-title').textContent = t.contactTitle;
            if (document.getElementById('contact-desc')) document.getElementById('contact-desc').textContent = t.contactDesc;
            if (document.getElementById('contact-copy-btn')) document.getElementById('contact-copy-btn').textContent = t.contactCopyBtn;
            if (document.getElementById('contact-app-btn')) document.getElementById('contact-app-btn').textContent = t.contactAppBtn;

            tabLogin.textContent = t.modalTabLogin;
            tabRegister.textContent = t.modalTabRegister;
            loginUser.placeholder = t.modalUser;
            loginPass.placeholder = t.modalPass;
            registerUser.placeholder = t.modalUser;
            registerPass.placeholder = t.modalPass;
            loginBtnText.textContent = t.modalBtnLogin;
            registerBtnText.textContent = t.modalBtnRegister;

            // Advanced Filters Drawer elements localization
            const settingsTitle = document.getElementById('settings-title');
            if (settingsTitle) settingsTitle.textContent = t.filtersTitle;
            const lblMinRating = document.getElementById('lbl-min-rating');
            if (lblMinRating) lblMinRating.textContent = t.filterMinRating;
            const optRatingAll = document.getElementById('opt-rating-all');
            if (optRatingAll) optRatingAll.textContent = t.filterMinRatingAll;
            const lblYear = document.getElementById('lbl-year');
            if (lblYear) lblYear.textContent = t.filterYear;
            const filterYear = document.getElementById('filter-year');
            if (filterYear) filterYear.placeholder = t.filterYearPlaceholder || 'e.g. 2019';


            // App Customization elements localization
            const settingsCustomTitle = document.getElementById('settings-custom-title');
            if (settingsCustomTitle) settingsCustomTitle.textContent = t.settingsCustomTitle;
            const lblContentType = document.getElementById('lbl-content-type');
            if (lblContentType) lblContentType.textContent = t.lblContentType;
            const optContentAny = document.getElementById('opt-content-any');
            if (optContentAny) optContentAny.textContent = t.optContentAny;
            const optContentMovie = document.getElementById('opt-content-movie');
            if (optContentMovie) optContentMovie.textContent = t.optContentMovie;
            const optContentSeries = document.getElementById('opt-content-series');
            if (optContentSeries) optContentSeries.textContent = t.optContentSeries;
            const lblSurpriseMe = document.getElementById('lbl-surprise-me');
            if (lblSurpriseMe) lblSurpriseMe.textContent = t.lblSurpriseMe;
            const descSurpriseMe = document.getElementById('desc-surprise-me');
            if (descSurpriseMe) descSurpriseMe.textContent = t.descSurpriseMe;
            const tooltipSurpriseMe = document.getElementById('tooltip-surprise-me');
            if (tooltipSurpriseMe) tooltipSurpriseMe.textContent = t.tooltipSurpriseMe;
            const lblRememberMe = document.getElementById('lbl-remember-me');
            if (lblRememberMe) lblRememberMe.textContent = t.lblRememberMe;
            const lblAccentTheme = document.getElementById('lbl-accent-theme');
            if (lblAccentTheme) lblAccentTheme.textContent = t.lblAccentTheme;
            const lblDisplayStyle = document.getElementById('lbl-display-style');
            if (lblDisplayStyle) lblDisplayStyle.textContent = t.lblDisplayStyle;
            const lblMaxResults = document.getElementById('lbl-max-results');
            if (lblMaxResults) lblMaxResults.textContent = t.lblMaxResults;

            // Select Option localizations
            const optThemeSky = document.getElementById('opt-theme-sky');
            if (optThemeSky) optThemeSky.textContent = t.optThemeSky;
            const optThemePurple = document.getElementById('opt-theme-purple');
            if (optThemePurple) optThemePurple.textContent = t.optThemePurple;
            const optThemeEmerald = document.getElementById('opt-theme-emerald');
            if (optThemeEmerald) optThemeEmerald.textContent = t.optThemeEmerald;
            const optThemeRose = document.getElementById('opt-theme-rose');
            if (optThemeRose) optThemeRose.textContent = t.optThemeRose;
            const optThemeAmber = document.getElementById('opt-theme-amber');
            if (optThemeAmber) optThemeAmber.textContent = t.optThemeAmber;

            const optDisplayStandard = document.getElementById('opt-display-standard');
            if (optDisplayStandard) optDisplayStandard.textContent = t.optDisplayStandard;
            const optDisplayCompact = document.getElementById('opt-display-compact');
            if (optDisplayCompact) optDisplayCompact.textContent = t.optDisplayCompact;
            
            setLoginState(isLoggedIn, currentUser); // refresh nav
        }

        langOptions.forEach(btn => {
            btn.addEventListener('click', () => {
                const selectedLang = btn.getAttribute('data-lang');
                if (currentLang !== selectedLang) {
                    currentLang = selectedLang;
                    localStorage.setItem('cinematch_lang', currentLang);
                    updateUI();
                    
                    // Re-fetch data for the new language
                    if (lastMovieData && !resultsContainer.classList.contains('hidden-section')) {
                        performSearch();
                    }
                    if (activeTab === 'watchlist') {
                        showWatchlistTab();
                    }
                }
                // Unfocus the dropdown to close it
                document.activeElement.blur();
            });
        });

        // Toggle Advanced Settings Drawer
        const toggleSettingsBtn = document.getElementById('toggle-settings-btn');
        const settingsDrawer = document.getElementById('settings-drawer');
        const settingsDivider = document.getElementById('settings-divider');
        if (toggleSettingsBtn && settingsDrawer) {
            toggleSettingsBtn.addEventListener('click', () => {
                settingsDrawer.classList.toggle('hidden');
                if (settingsDivider) {
                    settingsDivider.classList.toggle('hidden');
                }
            });
        }


        
        function showToast(message) {
            const toast = document.getElementById('toast-notification');
            document.getElementById('toast-message').textContent = message;
            toast.classList.remove('translate-y-[150%]');
            setTimeout(() => {
                toast.classList.add('translate-y-[150%]');
            }, 3000);
        }

        // --- Dynamic Trending Loading ---
        async function loadTrending() {
            const container = document.getElementById('trending-container');
            if (!container) return;
            container.innerHTML = `<span class="text-xs text-slate-500 animate-pulse">...</span>`;
            try {
                const res = await fetch('/api/trending');
                const data = await res.json();
                if (data.success && Array.isArray(data.trending) && data.trending.length > 0) {
                    container.innerHTML = data.trending.map(item => {
                        const escapedName = item.name.replace(/'/g, "\\'");
                        const escapedId = item.imdbId ? item.imdbId.replace(/'/g, "\\'") : '';
                        const escapedType = item.type ? item.type.replace(/'/g, "\\'") : '';
                        return `<button onclick="const input = document.getElementById('movie-input'); input.value='${escapedName}'; input.dataset.imdbId='${escapedId}'; input.dataset.contentType='${escapedType}'; input.dataset.lastTitle='${escapedName}'; document.getElementById('search-form').dispatchEvent(new Event('submit'))" class="px-3 py-1 rounded-full bg-slate-800/40 hover:bg-slate-700/80 text-slate-300 transition-colors border border-slate-700/50 text-xs">${item.name}</button>`;
                    }).join('');
                } else {
                    throw new Error("Invalid trending data");
                }
            } catch (e) {
                console.warn("Failed to load trending, using default fallback:", e);
                const fallbacks = currentLang === 'pt'
                    ? [
                        { name: "A Origem", imdbId: "tt1375666", type: "movie" },
                        { name: "Breaking Bad", imdbId: "tt0903747", type: "series" },
                        { name: "Interstellar", imdbId: "tt0816692", type: "movie" },
                        { name: "A Guerra dos Tronos", imdbId: "tt0944947", type: "series" },
                        { name: "Matrix", imdbId: "tt0133093", type: "movie" },
                        { name: "Stranger Things", imdbId: "tt5027774", type: "series" }
                      ]
                    : [
                        { name: "Inception", imdbId: "tt1375666", type: "movie" },
                        { name: "Breaking Bad", imdbId: "tt0903747", type: "series" },
                        { name: "Interstellar", imdbId: "tt0816692", type: "movie" },
                        { name: "Game of Thrones", imdbId: "tt0944947", type: "series" },
                        { name: "The Matrix", imdbId: "tt0133093", type: "movie" },
                        { name: "Stranger Things", imdbId: "tt5027774", type: "series" }
                      ];
                container.innerHTML = fallbacks.map(item => {
                    const escapedName = item.name.replace(/'/g, "\\'");
                    const escapedId = item.imdbId ? item.imdbId.replace(/'/g, "\\'") : '';
                    const escapedType = item.type ? item.type.replace(/'/g, "\\'") : '';
                    return `<button onclick="const input = document.getElementById('movie-input'); input.value='${escapedName}'; input.dataset.imdbId='${escapedId}'; input.dataset.contentType='${escapedType}'; input.dataset.lastTitle='${escapedName}'; document.getElementById('search-form').dispatchEvent(new Event('submit'))" class="px-3 py-1 rounded-full bg-slate-800/40 hover:bg-slate-700/80 text-slate-300 transition-colors border border-slate-700/50 text-xs">${item.name}</button>`;
                }).join('');
            }
        }

        // --- Experience Settings Management ---
        function applyDisplayStyle(styleVal) {
            const resultsContainer = document.getElementById('results-container');
            if (!resultsContainer) return;
            
            if (styleVal === 'compact') {
                document.body.classList.add('layout-compact');
                resultsContainer.classList.remove('grid-cols-1', 'sm:grid-cols-2', 'md:grid-cols-3', 'lg:grid-cols-5', 'gap-5');
                resultsContainer.classList.add('grid-cols-2', 'sm:grid-cols-3', 'md:grid-cols-4', 'lg:grid-cols-6', 'gap-3.5');
            } else {
                document.body.classList.remove('layout-compact');
                resultsContainer.classList.remove('grid-cols-2', 'sm:grid-cols-3', 'md:grid-cols-4', 'lg:grid-cols-6', 'gap-3.5');
                resultsContainer.classList.add('grid-cols-1', 'sm:grid-cols-2', 'md:grid-cols-3', 'lg:grid-cols-5', 'gap-5');
            }
        }

        function loadSettings() {
            // Theme setting
            const savedTheme = localStorage.getItem('cinematch_theme') || 'sky';
            const themeSelect = document.getElementById('setting-accent-theme');
            if (themeSelect) {
                themeSelect.value = savedTheme;
            }
            document.body.setAttribute('data-theme', savedTheme);
            
            // Max Results setting
            const savedMaxResults = localStorage.getItem('cinematch_max_results') || '10';
            const maxResultsSelect = document.getElementById('setting-max-results');
            const maxResultsVal = document.getElementById('max-results-val');
            if (maxResultsSelect) {
                maxResultsSelect.value = savedMaxResults;
            }
            if (maxResultsVal) {
                maxResultsVal.textContent = savedMaxResults;
            }
        }

        function registerSettingsListeners() {
            const themeSelect = document.getElementById('setting-accent-theme');
            if (themeSelect) {
                themeSelect.addEventListener('change', (e) => {
                    const val = e.target.value;
                    document.body.setAttribute('data-theme', val);
                    localStorage.setItem('cinematch_theme', val);
                });
            }

            const maxResultsVal = document.getElementById('max-results-val');
            const maxResultsSetting = document.getElementById('setting-max-results');
            if (maxResultsSetting) {
                maxResultsSetting.addEventListener('input', (e) => {
                    const val = e.target.value;
                    if (maxResultsVal) maxResultsVal.textContent = val;
                    localStorage.setItem('cinematch_max_results', val);
                    
                    // If recommendations are active, re-render immediately
                    if (lastMovieData && !resultsContainer.classList.contains('hidden-section') && activeTab === 'home') {
                        renderMovies(lastMovieData.referenceMovie, lastMovieData.recommendations, lastMovieData.cacheId);
                    }
                });
            }
        }

        // =========================================================================
        // MOTOR DE PERFORMANCE DESKTOP (Magia Visual e Zero Latency)
        // =========================================================================
        window.movieCache = window.movieCache || {};
        
        function initDesktopUX() {
            // Apenas executa em PCs/Macs com ratos de precisão
            if (!window.matchMedia("(pointer: fine)").matches) return;

            let hoverTimeout;
            
            document.addEventListener('mousemove', (e) => {
                const card = e.target.closest('.movie-card');
                if (!card) return;

                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;

                // Variáveis CSS para o efeito Spotlight (Lanterna radial)
                card.style.setProperty('--mouse-x', `${x}px`);
                card.style.setProperty('--mouse-y', `${y}px`);

                // Matemática de Tilt 3D
                const centerX = rect.width / 2;
                const centerY = rect.height / 2;
                const rotateX = ((y - centerY) / centerY) * -5;
                const rotateY = ((x - centerX) / centerX) * 5;

                card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02) translateY(-4px)`;
            }, { passive: true });

            document.addEventListener('mouseout', (e) => {
                const card = e.target.closest('.movie-card');
                if (card) {
                    card.style.transform = '';
                }
            });

            // Pre-fetching (Previsão de clique de 300ms com latência 0)
            document.addEventListener('mouseenter', (e) => {
                const card = e.target.closest('.movie-card');
                if (!card) return;
                
                const container = card.querySelector('[onclick*="openDetailsModal"]');
                if (!container) return;
                
                const onclickAttr = container.getAttribute('onclick');
                const match = onclickAttr.match(/'([^']+)'/);
                if (match && match[1]) {
                    try {
                        const m = JSON.parse(decodeURIComponent(atob(match[1])));
                        const cacheKey = m.imdb_id || m.imdbId || `${m.title}-${m.year}`;
                        
                        // Se não está na cache, saca silenciosamente antes do clique
                        if (!window.movieCache[cacheKey]) {
                            const titleQuery = encodeURIComponent(m.originalTitle || m.original_title || m.title || '');
                            const yearQuery = m.year ? `&y=${m.year}` : '';
                            const typeQuery = m.type ? `&type=${m.type}` : '';
                            
                            // Prefetching search data
                            fetch(`/api/search?q=${titleQuery}${yearQuery}${typeQuery}`)
                                .then(r => r.json())
                                .then(data => {
                                    if(data && data.success && data.data && data.data.length > 0) {
                                        window.movieCache[cacheKey] = data.data[0];
                                    }
                                }).catch(() => {});
                        }
                    } catch(err) {}
                }
            }, true);
        }

        // --- Initialization ---
        document.addEventListener('DOMContentLoaded', () => {
            initDesktopUX();
            loadSettings();
            updateUI();
            loadTrending();
            registerSettingsListeners();
            // Pre-fill username if remembered
            const savedUsername = localStorage.getItem('remembered_username');
            if (savedUsername) {
                const loginUser = document.getElementById('login-user');
                const loginRemember = document.getElementById('login-remember');
                if (loginUser) loginUser.value = savedUsername;
                if (loginRemember) loginRemember.checked = true;
            }
            
            // Handle URL parameters for state persistence on refresh
            const urlParams = new URLSearchParams(window.location.search);
            const qParam = urlParams.get('q');
            const tabParam = urlParams.get('tab');
            
            // Allow state to initialize naturally via the standard login check
            // which runs checkSession() -> setLoginState() etc.
            checkSession();
            
            // We'll queue the search or tab switch immediately after checking session.
            setTimeout(() => {
                if (qParam) {
                    movieInput.value = qParam;
                    performSearch();
                } else if (tabParam === 'watchlist') {
                    showWatchlistTab(false); // false = don't push state again
                } else if (window.location.pathname.startsWith('/shared/')) {
                    // Do nothing, handled by checkSharedRoute()
                } else {
                    window.history.replaceState({ view: 'home' }, '', '/');
                }
            }, 300); // Small delay to let checkSession finish its UI logic
        });
        
        let isPopStateAction = false;
        window.addEventListener('popstate', (e) => {
            const state = e.state;
            if (!state || !state.view || state.view === 'home') {
                goHome(false);
                return;
            }
            if (state.view === 'search') {
                movieInput.value = state.query;
                isPopStateAction = true;
                performSearch();
            } else if (state.view === 'watchlist') {
                showWatchlistTab(false);
            } else if (state.view === 'share') {
                window.location.search = `?share=${state.id}`;
            }
        });

        // Handle shared lists on load (called from the first DOMContentLoaded logic if needed, but actually checkSession handles it)

        async function checkSession() {
            const isShared = await handleSharedList();
            try {
                const res = await fetch('/api/me', { credentials: 'include' });
                const data = await res.json();
                if (data.loggedIn) {
                    isLoggedIn = true;
                    currentDisplayName = data.display_name || '';
                    currentUserAvatar = data.avatar_url || '';
                    await loadUserWatchlist();
                    setLoginState(true, data.username);
                    if (!isShared && activeTab === 'watchlist') {
                        showWatchlistTab();
                    }
                } else {
                    setLoginState(false);
                }
            } catch (e) {
                setLoginState(false);
            }
        }

        function setLoginState(loggedIn, username = '') {
            isLoggedIn = loggedIn;
            currentUser = username;
            const t = dict[currentLang];
            
            if (loggedIn) {
                navActions.innerHTML = `
                    <button id="nav-watchlist-btn" onclick="toggleWatchlistTab()" class="text-xs font-bold px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-lg bg-sky-600/10 hover:bg-sky-600/20 text-sky-400 hover:text-sky-300 border border-sky-500/20 hover:border-sky-500/40 transition-all duration-300 uppercase tracking-wider flex items-center gap-1 sm:gap-1.5 shadow-sm">
                        <svg class="w-3.5 h-3.5" fill="${activeTab === 'watchlist' ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                        <span><span class="hidden sm:inline">${t.navWatchlist}</span></span>
                    </button>
                    <div class="relative group">
                        <button class="flex items-center gap-1.5 sm:gap-2 bg-slate-900/60 border border-slate-700/50 rounded-lg px-1.5 py-1 sm:px-2.5 sm:py-1.5 text-xs font-sans shadow-sm backdrop-blur-md hover:bg-slate-800 transition-colors">
                            <div class="w-6 h-6 rounded-full bg-slate-800 border border-slate-600 flex items-center justify-center overflow-hidden flex-shrink-0">
                                ${currentUserAvatar ? `<img loading=" lazy\ decoding=\async\ src="${currentUserAvatar}" class="w-full h-full object-cover">` : `<span class="text-[10px] font-bold text-white bg-gradient-to-br from-sky-500 to-indigo-500 w-full h-full flex items-center justify-center">${(currentDisplayName || username || '?').charAt(0).toUpperCase()}</span>`}
                            </div>
                            <span class="text-slate-300 font-medium pr-1.5"><span class="text-white font-bold">${currentDisplayName || username}</span></span>
                            <svg class="w-3 h-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div class="absolute right-0 top-full pt-3 -mt-2 w-40 z-50 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-200">
                            <div class="bg-slate-800 border border-slate-700 rounded-md shadow-xl overflow-hidden flex flex-col">
                                <button onclick="openProfileModal()" class="w-full text-left px-4 py-2.5 text-xs font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors border-b border-slate-700">${t.navProfile}</button>
                                <button onclick="logout()" class="w-full text-left px-4 py-2.5 text-xs font-medium text-red-400 hover:bg-slate-700 hover:text-red-300 transition-colors uppercase tracking-wider">${t.navLogout}</button>
                            </div>
                        </div>
                    </div>
                `;
                
                // Show Watchlist Preview on frontpage
                const fpWatchlistSection = document.getElementById('frontpage-watchlist-section');
                if (fpWatchlistSection) {
                    fpWatchlistSection.classList.remove('hidden');
                    const firstName = (currentDisplayName || username || '').split(' ')[0];
                    if (firstName) {
                        document.getElementById('frontpage-greeting').textContent = `Welcome back, ${firstName}!`;
                    }
                    setTimeout(forceRefreshWatchlist, 100); // Fetch latest and render
                }
            } else {
                navActions.innerHTML = `
                    <button onclick="openModal('login')" class="text-xs sm:text-sm text-slate-300 hover:text-white font-medium px-1.5 sm:px-2 transition-colors">${t.navLogin}</button>
                    <button onclick="openModal('register')" class="text-xs sm:text-sm bg-slate-800 hover:bg-slate-700 border border-slate-700 text-white font-medium px-2.5 py-1.5 sm:px-4 sm:py-1.5 rounded-md transition-colors shadow-sm">${t.navRegister}</button>
                `;
                const fpWatchlistSection = document.getElementById('frontpage-watchlist-section');
                if (fpWatchlistSection) {
                    fpWatchlistSection.classList.add('hidden');
                }
            }
        }

        function goHome(pushState = true) {
            activeTab = 'home';
            const hideIds = ['watchlist-header-container', 'reference-movie-container', 'results-container'];
            const showIds = ['hero-header', 'features-section', 'dynamic-bg', 'search-container'];
            if (isLoggedIn) showIds.push('frontpage-watchlist-section');
            else hideIds.push('frontpage-watchlist-section');
            
            transitionTo(hideIds, showIds, () => {
                const shareHeader = document.getElementById('share-header');
                if (shareHeader) shareHeader.remove();
                isPublicShareMode = false;
                
                searchContainer.classList.replace('mb-4', 'mb-8');
                movieInput.value = '';
                lastSearchedMovie = '';
                lastMovieData = null;
                
                if (pushState) {
                    if (!window.history.state || window.history.state.view !== 'home') {
                        window.history.pushState({ view: 'home' }, '', '/');
                    }
                }
                setLoginState(isLoggedIn, currentUser);
            });
        }

        async function logout() {
            await fetch('/api/logout', { method: 'POST' });
            setLoginState(false);
            userWatchlist = [];
            goHome();
        }

        // Modal Logic
        const profileModal = document.getElementById('profile-modal');
        
        async function openProfileModal() {
            try {
                const res = await fetch('/api/profile', { credentials: 'include' });
                if (res.ok) {
                    const prefs = await res.json();
                    document.getElementById('prof-lang').value = prefs.language || 'en';
                    document.getElementById('prof-type').value = prefs.defaultType || 'any';
                    document.getElementById('prof-rating').value = prefs.minRating || '';
                    document.getElementById('prof-display-name').value = currentDisplayName || currentUser || '';
                    if (currentUserAvatar) {
                        document.getElementById('prof-avatar-preview').src = currentUserAvatar;
                        document.getElementById('prof-avatar-preview').classList.remove('hidden');
                        document.getElementById('prof-avatar-initials').classList.add('hidden');
                    } else {
                        document.getElementById('prof-avatar-preview').classList.add('hidden');
                        document.getElementById('prof-avatar-initials').classList.remove('hidden');
                        document.getElementById('prof-avatar-initials').textContent = (currentDisplayName || currentUser || '?').charAt(0).toUpperCase();
                    }
                    
                    const favs = prefs.favoriteGenres || [];
                    const excs = prefs.excludedGenres || [];
                    
                    const genreGrid = document.getElementById('genre-grid');
                    genreGrid.innerHTML = '';
                    
                    AVAILABLE_GENRES.forEach(g => {
                        const pill = document.createElement('button');
                        pill.type = 'button';
                        pill.dataset.genre = g;
                        
                        const updatePillVisuals = (state) => {
                            if (state === 'fav') {
                                pill.className = 'px-3 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 select-none bg-emerald-950/40 text-emerald-300 border-emerald-500/50 shadow-[0_0_10px_rgba(16,185,129,0.1)]';
                                pill.innerHTML = `<span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"></path></svg> ${g}</span>`;
                                pill.dataset.state = 'fav';
                            } else if (state === 'exc') {
                                pill.className = 'px-3 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 select-none bg-red-950/40 text-red-300 border-red-500/50 shadow-[0_0_10px_rgba(239,68,68,0.1)]';
                                pill.innerHTML = `<span class="flex items-center gap-1.5"><svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path></svg> ${g}</span>`;
                                pill.dataset.state = 'exc';
                            } else {
                                pill.className = 'px-3 py-1.5 rounded-full text-sm font-medium border transition-all duration-200 select-none bg-slate-800 border-slate-700 text-slate-300 hover:bg-slate-700 hover:text-white';
                                pill.innerHTML = `<span>${g}</span>`;
                                pill.dataset.state = 'neutral';
                            }
                        };
                        
                        let initialState = 'neutral';
                        if (favs.includes(g)) initialState = 'fav';
                        else if (excs.includes(g)) initialState = 'exc';
                        
                        updatePillVisuals(initialState);
                        
                        pill.addEventListener('click', () => {
                            if (pill.dataset.state === 'neutral') updatePillVisuals('fav');
                            else if (pill.dataset.state === 'fav') updatePillVisuals('exc');
                            else updatePillVisuals('neutral');
                        });
                        
                        genreGrid.appendChild(pill);
                    });
                }
            } catch (e) {
                console.error("Could not fetch profile", e);
            }
            
            // Apply translations to modal
            const t = dict[currentLang];
            document.getElementById('modal-profile-title').textContent = t.profileTitle;
            const titleDesc = document.getElementById('modal-profile-desc');
            if (titleDesc) titleDesc.textContent = currentLang === 'pt' ? 'Afina o teu algoritmo para resultados personalizados' : 'Tune your algorithm for personalized results';
            document.getElementById('lbl-prof-lang').textContent = t.profileLanguage;
            document.getElementById('lbl-prof-type').textContent = t.profileDefaultType;
            document.getElementById('lbl-prof-fav').textContent = t.profileFavGenres;
            
            const helpTxt = document.getElementById('lbl-prof-genres-help');
            if (helpTxt) helpTxt.textContent = currentLang === 'pt' ? 'Clica para alternar' : 'Click to toggle';
            
            document.getElementById('lbl-prof-rating').textContent = t.profileMinRating;
            document.getElementById('prof-btn-text').textContent = t.profileSaveBtn;
            
            profileModal.classList.remove('hidden');
            setTimeout(() => profileModal.classList.add('active'), 10);
        }

        function closeProfileModal() {
            profileModal.classList.remove('active');
            setTimeout(() => profileModal.classList.add('hidden'), 300);
        }

        document.getElementById('profile-form').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = document.getElementById('prof-btn-text');
            const loader = document.getElementById('prof-loader');
            btn.classList.add('hidden');
            loader.classList.remove('hidden');

            const favStr = Array.from(document.querySelectorAll('#genre-grid button[data-state="fav"]')).map(b => b.dataset.genre);
            const excStr = Array.from(document.querySelectorAll('#genre-grid button[data-state="exc"]')).map(b => b.dataset.genre);

            const prefs = {
                language: document.getElementById('prof-lang').value,
                defaultType: document.getElementById('prof-type').value,
                favoriteGenres: favStr,
                excludedGenres: excStr,
                minRating: document.getElementById('prof-rating').value
            };

            const displayName = document.getElementById('prof-display-name').value.trim();
            const avatarUrl = document.getElementById('prof-avatar-preview').src;
            const usingPreset = avatarUrl.includes('/assets/avatars/');

            try {
                // Update profile preferences
                await fetch('/api/profile', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ preferences: prefs })
                });

                // Update display name and optionally preset avatar
                await fetch('/api/profile/update-display', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ display_name: displayName, avatar_url: usingPreset ? new URL(avatarUrl).pathname : undefined })
                });
                
                currentDisplayName = displayName;
                if (usingPreset) currentUserAvatar = new URL(avatarUrl).pathname;
                
                // If language changed, update site globally
                if (prefs.language !== currentLang) {
                    currentLang = prefs.language;
                    localStorage.setItem('cinematch_lang', currentLang);
                    updateUI();
                }
                
                setLoginState(true, currentUser); // Refresh nav text and avatar
                
                loader.classList.add('hidden');
                btn.classList.remove('hidden');
                showToast(dict[currentLang].profileSavedToast || "Profile saved!");
            } catch (e) {
                console.error("Profile save error:", e);
                loader.classList.add('hidden');
                btn.classList.remove('hidden');
            }
        });

        async function handleAvatarUpload(files) {
            if (!files || files.length === 0) return;
            const file = files[0];
            const formData = new FormData();
            formData.append('avatar', file);

            try {
                const res = await fetch('/api/profile/upload-avatar', {
                    method: 'POST',
                    body: formData,
                    credentials: 'include'
                });
                const data = await res.json();
                if (data.success) {
                    currentUserAvatar = data.avatar_url;
                    document.getElementById('prof-avatar-preview').src = data.avatar_url;
                    document.getElementById('prof-avatar-preview').classList.remove('hidden');
                    document.getElementById('prof-avatar-initials').classList.add('hidden');
                    setLoginState(true, currentUser); // Refresh nav text and avatar
                    showToast("Avatar uploaded successfully!");
                } else {
                    showToast(data.error || "Upload failed");
                }
            } catch (err) {
                console.error("Upload error", err);
                showToast("Server error during upload");
            }
        }

        function selectPresetAvatar(path) {
            document.getElementById('prof-avatar-preview').src = path;
            document.getElementById('prof-avatar-preview').classList.remove('hidden');
            document.getElementById('prof-avatar-initials').classList.add('hidden');
        }
        const supportModal = document.getElementById('support-modal');
        function openModal(mode = 'login') {
            authModal.classList.add('active');
            if (mode === 'login') {
                tabLogin.click();
            } else {
                tabRegister.click();
            }
        }
        
        async function fetchLeaderboard() {
            const list = document.getElementById('leaderboard-list');
            try {
                const res = await fetch('/api/donations/leaderboard');
                const data = await res.json();
                if (data.success && data.leaderboard) {
                    if (data.leaderboard.length === 0) {
                        list.innerHTML = '<div class="text-center text-slate-500 text-sm py-4">Be the first to support!</div>';
                    } else {
                        list.innerHTML = data.leaderboard.map((d, i) => {
                            let icon = '';
                            if (i === 0) icon = '🥇';
                            else if (i === 1) icon = '🥈';
                            else if (i === 2) icon = '🥉';
                            else icon = '<span class="text-xs text-slate-500 inline-block w-4">' + (i+1) + '.</span>';
                            
                            return `
                                <div class="flex items-center justify-between bg-slate-800/50 p-2.5 rounded-md border border-slate-700/50">
                                    <div class="flex items-center gap-2">
                                        <div class="flex items-center justify-center">${icon}</div>
                                        <span class="text-slate-200 font-medium">${d.username}</span>
                                    </div>
                                    <div class="text-pink-400 font-bold">${parseFloat(d.total_amount).toFixed(2)}€</div>
                                </div>
                            `;
                        }).join('');
                    }
                }
            } catch (err) {
                console.error(err);
                list.innerHTML = '<div class="text-center text-red-500 text-sm py-4">Failed to load leaderboard.</div>';
            }
        }

        function openSupportModal() {
            supportModal.classList.add('active');
            fetchLeaderboard();
        }

        function closeSupportModal() {
            supportModal.classList.remove('active');
        }

        supportModal.addEventListener('click', (e) => {
            if (e.target === supportModal) supportModal.classList.remove('active');
        });

        closeModalBtn.addEventListener('click', () => {
            authModal.classList.remove('active');
        });

        authModal.addEventListener('click', (e) => {
            if (e.target === authModal) authModal.classList.remove('active');
        });

        // Close trailer modal on backdrop click
        const trailerModal = document.getElementById('trailer-modal');
        if (trailerModal) {
            trailerModal.addEventListener('click', (e) => {
                if (e.target === trailerModal) closeTrailer();
            });
        }

        tabLogin.addEventListener('click', () => {
            isLoginMode = true;
            tabLogin.classList.replace('text-slate-500', 'text-sky-500');
            tabLogin.classList.add('border-b-2', 'border-sky-500');
            tabRegister.classList.replace('text-sky-500', 'text-slate-500');
            tabRegister.classList.remove('border-b-2', 'border-sky-500');
            loginForm.classList.remove('hidden');
            registerForm.classList.add('hidden');
            loginForm.reset();
            registerForm.reset();
            authError.classList.add('hidden');
        });

        tabRegister.addEventListener('click', () => {
            isLoginMode = false;
            tabRegister.classList.replace('text-slate-500', 'text-sky-500');
            tabRegister.classList.add('border-b-2', 'border-sky-500');
            tabLogin.classList.replace('text-sky-500', 'text-slate-500');
            tabLogin.classList.remove('border-b-2', 'border-sky-500');
            registerForm.classList.remove('hidden');
            loginForm.classList.add('hidden');
            loginForm.reset();
            registerForm.reset();
            authError.classList.add('hidden');
        });

        async function handleAuthSubmit(e, isLogin) {
            e.preventDefault();
            authError.classList.add('hidden');
            const username = isLogin ? loginUser.value.trim() : registerUser.value.trim();
            const password = isLogin ? loginPass.value : registerPass.value;
            const endpoint = isLogin ? '/api/login' : '/api/register';

            const rememberMe = isLogin ? (document.getElementById('login-remember') ? document.getElementById('login-remember').checked : false) : false;

            try {
                const res = await fetch(endpoint, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    credentials: 'include',
                    body: JSON.stringify({ username, password, rememberMe })
                });
                const data = await res.json();

                if (res.ok && data.success) {
                    // Save or remove remembered username
                    if (isLogin) {
                        const loginRemember = document.getElementById('login-remember');
                        if (loginRemember && loginRemember.checked) {
                            localStorage.setItem('remembered_username', username);
                        } else {
                            localStorage.removeItem('remembered_username');
                        }

                        // Trigger native browser save password prompt
                        if (window.PasswordCredential) {
                            try {
                                const cred = new PasswordCredential({
                                    id: username,
                                    password: password
                                });
                                navigator.credentials.store(cred).catch(err => console.error("Error storing credentials", err));
                            } catch (e) {
                                console.error("Error building PasswordCredential", e);
                            }
                        }
                    }

                    authModal.classList.remove('active');
                    // Delay reset slightly to let browser credentials heuristics capture the input values before clearing
                    setTimeout(() => {
                        if (isLogin) loginForm.reset(); else registerForm.reset();
                    }, 1000);
                    isLoggedIn = true;
                    currentDisplayName = data.user.display_name || '';
                    currentUserAvatar = data.user.avatar_url || '';
                    await new Promise(r => setTimeout(r, 300));
                    await loadUserWatchlist();
                    setLoginState(true, data.user.username);
                    
                    if (movieInput.value.trim() !== '') {
                        searchForm.dispatchEvent(new Event('submit'));
                    }
                } else {
                    authError.textContent = data.error || dict[currentLang].errAuth;
                    authError.classList.remove('hidden');
                }
            } catch (err) {
                authError.textContent = dict[currentLang].errServer;
                authError.classList.remove('hidden');
            }
        }

        loginForm.addEventListener('submit', (e) => handleAuthSubmit(e, true));
        registerForm.addEventListener('submit', (e) => handleAuthSubmit(e, false));

        
        const loadingPhrases = [
            typeof t !== 'undefined' && t.loading ? t.loading : "A carregar...",
            "A preparar as pipocas...",
            "A escurecer a sala...",
            "A consultar os realizadores...",
            "A afinar o som surround...",
            "A rebobinar a fita..."
        ];
        let loadingInterval;
        let phraseIndex = 0;

        function startLoadingText() {
            const loadingText = document.querySelector('#loading span:last-child');
            if(!loadingText) return;
            loadingText.textContent = loadingPhrases[0];
            phraseIndex = 1;
            loadingInterval = setInterval(() => {
                loadingText.textContent = loadingPhrases[phraseIndex];
                phraseIndex = (phraseIndex + 1) % loadingPhrases.length;
            }, 2000);
        }

        function stopLoadingText() {
            clearInterval(loadingInterval);
        }

        searchForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            await performSearch();
        });

        const movieTrivia = {
            pt: [
                "Sabias que o Arnold Schwarzenegger só disse 74 palavras no primeiro Exterminador Implacável?",
                "O código verde em The Matrix é feito de receitas de sushi digitalizadas.",
                "O Senhor dos Anéis e Matrix usaram a mesma cidade para filmagens no mesmo dia.",
                "A respiração do Darth Vader foi gravada a partir de um aparelho de mergulho.",
                "Hitchcock usou xarope de chocolate Bosco como sangue no filme Psicose.",
                "Os dinossauros aparecem apenas durante 15 minutos em Jurassic Park (1993).",
                "As vozes dos velociraptors a comunicar em Jurassic Park são tartarugas a acasalar.",
                "A fala 'Estou a falar contigo?' em Taxi Driver foi improvisada por Robert De Niro.",
                "A máscara de Michael Myers no Halloween é uma máscara do Capitão Kirk pintada de branco.",
                "O gato de Don Corleone em O Padrinho era um gato vadio encontrado no estúdio de gravação.",
                "O verdadeiro nome do R2-D2 provém de 'Reel 2, Dialog 2' durante as gravações.",
                "O orçamento de Blair Witch Project foi de apenas 60.000$, mas rendeu 248 milhões."
            ],
            en: [
                "Did you know Arnold Schwarzenegger only said 74 words in the first Terminator?",
                "The green code in The Matrix is actually digitized sushi recipes.",
                "The Lord of the Rings and The Matrix used the same city for filming on the same day.",
                "Darth Vader's suit used the breathing sound from a scuba regulator.",
                "Hitchcock used Bosco chocolate syrup as blood in the movie Psycho.",
                "Dinosaurs only appear for 15 minutes in Jurassic Park (1993).",
                "The voices of the communicating velociraptors in Jurassic Park are mating tortoises.",
                "The line 'You talkin' to me?' in Taxi Driver was improvised by Robert De Niro.",
                "Michael Myers' mask in Halloween is just a Captain Kirk mask painted white.",
                "Don Corleone's cat in The Godfather was a stray found roaming the studio lot.",
                "R2-D2's name comes from 'Reel 2, Dialog 2' during filming.",
                "The Blair Witch Project budget was only $60,000, but it grossed $248 million."
            ]
        };

        async function performSearch(isLoadMore = false) {
            const t = dict[currentLang];
            
            if (!isLoggedIn) {
                document.getElementById('modal-subtitle').textContent = t.errLoginReq;
                document.getElementById('modal-subtitle').classList.replace('text-sky-400', 'text-amber-400');
                openModal('login');
                return;
            }

            const movie = movieInput.value.trim() || lastSearchedMovie;
            if(!movie) return;

            let imdbId = '';
            let trendingType = '';
            if (movieInput.dataset.lastTitle === movie) {
                imdbId = movieInput.dataset.imdbId || '';
                trendingType = movieInput.dataset.contentType || '';
            } else {
                delete movieInput.dataset.imdbId;
                delete movieInput.dataset.contentType;
                delete movieInput.dataset.lastTitle;
            }
            
            if (!isPopStateAction) {
                if (!window.history.state || window.history.state.view !== 'search') {
                    window.history.pushState({ view: 'search', query: movie }, '', `?q=${encodeURIComponent(movie)}`);
                } else {
                    window.history.replaceState({ view: 'search', query: movie }, '', `?q=${encodeURIComponent(movie)}`);
                }
            }
            isPopStateAction = false;
            
            lastSearchedMovie = movie;

            // Extract Filters
            const afterYear = document.getElementById('filter-year').value || '';
            const minRating = document.getElementById('filter-min-rating').value || '';
            const excludeGenres = document.getElementById('filter-exclude-genres') ? document.getElementById('filter-exclude-genres').value : '';
            const defaultType = document.getElementById('filter-content-type').value || 'any';
            const surpriseMe = document.getElementById('filter-surprise-me').checked || false;

            const hideIds = ['hero-header', 'features-section', 'dynamic-bg', 'watchlist-header-container', 'frontpage-watchlist-section'];
            const showIds = ['results-container', 'reference-movie-container'];

            transitionTo(hideIds, showIds, () => {
                searchContainer.classList.replace('mb-8', 'mb-4');
                errorMsg.classList.add('hidden');
                resultsContainer.style.opacity = '0';
                resultsContainer.innerHTML = '';
                referenceMovieContainer.style.opacity = '0';
                referenceMovieContainer.innerHTML = '';
                
                // Show Premium Loading State
                if (window.loadingInterval) clearInterval(window.loadingInterval);
                resultsContainer.innerHTML = `
                    <div class="col-span-full flex flex-col items-center justify-center py-20 animate-fade-in-up">
                        <div class="relative w-32 h-32 mb-8 flex items-center justify-center">
                            <!-- Outer Glowing Ring -->
                            <div class="absolute inset-0 rounded-full border-2 border-transparent border-t-sky-400 border-r-indigo-500 animate-[spin_3s_linear_infinite] opacity-70 blur-[1px]"></div>
                            <!-- Middle Dashed Ring -->
                            <div class="absolute inset-2 rounded-full border border-dashed border-sky-300/50 animate-[spin_4s_linear_infinite_reverse]"></div>
                            <!-- Inner Core -->
                            <div class="absolute inset-6 rounded-full bg-gradient-to-tr from-sky-600 to-indigo-600 animate-pulse shadow-[0_0_30px_rgba(56,189,248,0.6)]"></div>
                            <!-- Center Icon -->
                            <svg class="w-8 h-8 text-white relative z-10 animate-bounce" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path></svg>
                        </div>
                        
                        <div class="flex flex-col items-center text-center max-w-md px-4">
                            <h3 class="text-2xl font-black bg-clip-text text-transparent bg-gradient-to-r from-sky-300 to-indigo-400 mb-3 tracking-tight">${t.loadingMsg}</h3>
                            <p id="dynamic-loading-text" class="text-slate-300 font-medium h-6 transition-opacity duration-300">${t.loadingSteps ? t.loadingSteps[0] : 'Powered by CineMatch AI'}</p>
                            <div class="mt-8 w-64 h-1.5 bg-slate-800 rounded-full overflow-hidden relative shadow-inner">
                                <div class="absolute top-0 bottom-0 left-0 bg-gradient-to-r from-sky-400 to-indigo-500 rounded-full animate-loading-bar"></div>
                            </div>
                            <p id="dynamic-trivia-text" class="text-sky-400 italic text-sm mt-6 transition-opacity duration-500 min-h-[40px] px-2 font-medium max-w-sm mx-auto"></p>
                        </div>
                        
                        <!-- Background ghost skeleton hint -->
                        <div class="w-full hidden sm:flex justify-center gap-4 mt-16 opacity-30 pointer-events-none scale-95 origin-top">
                            ${Array(5).fill('').map((_, i) => `
                                <div class="w-48 h-72 rounded-xl bg-slate-800/50 border border-slate-700/50 animate-pulse" style="animation-delay: ${i * 150}ms"></div>
                            `).join('')}
                        </div>
                    </div>
                `;
                
                resultsContainer.style.opacity = '1';

                // Start dynamic text rotation
                if (t.loadingSteps) {
                    let stepIndex = 0;
                    const dynamicText = document.getElementById('dynamic-loading-text');
                    const triviaText = document.getElementById('dynamic-trivia-text');
                    const triviaList = movieTrivia[currentLang] || movieTrivia['en'];
                    
                    if (triviaText) {
                        triviaText.innerText = triviaList[Math.floor(Math.random() * triviaList.length)];
                    }

                    let tickCount = 0;
                    window.loadingInterval = setInterval(() => {
                        stepIndex = (stepIndex + 1) % t.loadingSteps.length;
                        tickCount++;
                        
                        if (dynamicText) {
                            dynamicText.style.opacity = '0';
                            setTimeout(() => {
                                dynamicText.innerText = t.loadingSteps[stepIndex];
                                dynamicText.style.opacity = '1';
                            }, 300);
                        }

                        if (tickCount % 2 === 0 && triviaText) {
                            triviaText.style.opacity = '0';
                            setTimeout(() => {
                                triviaText.innerText = triviaList[Math.floor(Math.random() * triviaList.length)];
                                triviaText.style.opacity = '1';
                            }, 500);
                        }
                    }, 2000);
                }
            });
            
            btnText.classList.add('hidden');
            btnLoader.classList.remove('hidden');
            searchBtn.disabled = true;

            // Local cache key using query filters to prevent collisions
            const cacheKey = `cinematch_cache_${movie.toLowerCase()}_${currentLang}_y:${afterYear}_r:${minRating}_e:${excludeGenres.toLowerCase().trim()}_t:${defaultType}_s:${surpriseMe}${imdbId ? '_id:' + imdbId : ''}`;
            const localCache = localStorage.getItem(cacheKey);
            
            if (localCache) {
                try {
                    const data = JSON.parse(localCache);
                    // Ensure the cache is not legacy (must contain the trailerYtId property check)
                    if (data && data.referenceMovie && data.referenceMovie.hasOwnProperty('trailerYtId')) {
                        setTimeout(() => {
                            resultsContainer.style.opacity = '0';
                            setTimeout(() => {
                                lastMovieData = data;
                                currentCacheId = data.cacheId;
                                currentOffset = data.recommendations.length;
                                hasMoreResults = data.hasMore || false;
                                renderMovies(data.referenceMovie, data.recommendations, data.cacheId);
                                btnText.classList.remove('hidden');
                                btnLoader.classList.add('hidden');
                                searchBtn.disabled = false;
                                if (window.loadingInterval) clearInterval(window.loadingInterval);
                            }, 300);
                        }, 500);
                        return;
                    }
                } catch(e) {
                    // Ignore broken cache
                }
            }

            try {
                const payload = { 
                        movie, 
                        imdbId,
                        type: trendingType,
                        language: currentLang,
                        afterYear,
                        minRating,
                        excludeGenres,
                        defaultType,
                        surpriseMe,
                        limit: 5,
                        excludeTitles: isLoadMore ? (lastMovieData && lastMovieData.recommendations ? lastMovieData.recommendations.map(r => r.originalTitle || r.title) : []) : []
                    };
                const response = await fetch('/api/recommend', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (response.status === 401) {
                    setLoginState(false);
                    openModal('login');
                    return;
                }

                const data = await response.json();
                
                resultsContainer.style.opacity = '0'; // fade out skeleton
                setTimeout(() => {
                    if (!response.ok) {
                        if (response.status === 429 || (data.error && data.error.includes('Rate limit'))) {
                            showError(t.errRateLimit);
                        } else if (response.status === 503 || data.error === 'high_demand') {
                            showError(t.errHighDemand);
                        } else if (data.error) {
                            showError(data.error);
                        } else {
                            showError(t.errServer);
                        }
                    } else if (data.recommendations && data.recommendations.length > 0) {
                        lastMovieData = data;
                        currentCacheId = data.cacheId;
                        currentOffset = data.recommendations.length;
                        hasMoreResults = data.hasMore || false;
                        
                        try { localStorage.setItem(cacheKey, JSON.stringify(data)); } catch(e){}
                        renderMovies(data.referenceMovie, data.recommendations, data.cacheId);
                    } else {
                        showError(t.errNoRecs);
                    }
                }, 300);

            } catch (err) {
                showError(t.errUnexpected);
            } finally {
                if (window.loadingInterval) clearInterval(window.loadingInterval);
                btnText.classList.remove('hidden');
                btnLoader.classList.add('hidden');
                searchBtn.disabled = false;
            }
        }

        function showError(message) {
            errorMsg.textContent = message;
            errorMsg.classList.remove('hidden');
            if (window.loadingInterval) clearInterval(window.loadingInterval);
            resultsContainer.innerHTML = '';
            resultsContainer.style.opacity = '0';
        }

        const loadMoreContainer = document.getElementById('load-more-container');
        const btnLoadMore = document.getElementById('btn-load-more');
        const loadMoreText = document.getElementById('load-more-text');
        const loadMoreSpinner = document.getElementById('load-more-spinner');
        
        let currentCacheId = null;
        let currentOffset = 0;
        let hasMoreResults = false;

        btnLoadMore.addEventListener('click', async () => {
            if (!currentCacheId || !hasMoreResults) return;
            
            loadMoreText.classList.add('hidden');
            loadMoreSpinner.classList.remove('hidden');
            btnLoadMore.disabled = true;
            
            try {
                const payload = { 
                    cacheId: currentCacheId,
                    offset: currentOffset,
                    language: currentLang
                };

                const response = await fetch('/api/recommend/more', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                if (response.status === 401) {
                    setLoginState(false);
                    openModal('login');
                    return;
                }
                
                const data = await response.json();
                if (data.recommendations && data.recommendations.length > 0) {
                    currentOffset += data.recommendations.length;
                    renderMovies(null, data.recommendations, currentCacheId, true);
                    hasMoreResults = data.hasMore;
                    
                    if (lastMovieData && lastMovieData.recommendations) {
                        lastMovieData.recommendations = lastMovieData.recommendations.concat(data.recommendations);
                    }
                    
                    if (!hasMoreResults) {
                        loadMoreContainer.classList.add('hidden');
                        loadMoreContainer.classList.add('hidden-section');
                    }
                }
            } catch (e) {
                console.error("Load more failed:", e);
            } finally {
                loadMoreText.classList.remove('hidden');
                loadMoreSpinner.classList.add('hidden');
                btnLoadMore.disabled = false;
            }
        });

        function renderMovies(refMovie, movies, cacheId = null, isAppend = false) {
            const t = dict[currentLang];
            
            if (!isAppend) {
                resultsContainer.innerHTML = '';
                resultsContainer.style.opacity = '0';
                loadMoreContainer.classList.add('hidden');
                loadMoreContainer.classList.add('hidden-section');
                loadMoreContainer.style.opacity = '0';
            }

            if (refMovie && !isAppend) {
                const refArtwork = refMovie.poster ? refMovie.poster : (refMovie.imdbId ? `https://images.metahub.space/poster/medium/${refMovie.imdbId}/img` : `https://ui-avatars.com/api/?name=${encodeURIComponent(refMovie.title)}&background=1e293b&color=fff&size=500`);
                const refImgId = `ref-poster-${Date.now()}`;
                const refImdbLinkId = `ref-imdb-link-${Date.now()}`;
                
                const isRefSeries = (refMovie.type === 'series' || refMovie.type === 'tv');
                const refTypeLabel = isRefSeries ? t.typeSeries : t.typeMovie;
                const refTypeBadgeClass = isRefSeries
                    ? 'bg-purple-500/20 text-purple-400 border-purple-500/30'
                    : 'bg-sky-500/20 text-sky-400 border-sky-500/30';

                referenceMovieContainer.innerHTML = `
                    <div class="flex flex-col sm:flex-row items-center gap-4 bg-slate-800/60 border border-slate-700/50 px-5 py-3 rounded-xl mb-4 animate-fade-in-up w-full md:w-auto glass-panel">
                        <div class="flex items-center gap-4 flex-1">
                            <img loading=\lazy\ decoding=\async\ id="${refImgId}" src="${refArtwork}" alt="${refMovie.title}" class="w-8 h-12 object-cover rounded shadow-md border border-slate-600/50 transition-all duration-300" onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=${encodeURIComponent(refMovie.title)}&background=1e293b&color=fff&size=500';">
                            <div class="flex flex-col text-left font-sans">
                                <div class="flex items-center gap-2 mb-0.5">
                                    <span class="text-[10px] text-sky-400 font-bold tracking-wider uppercase">${t.refPrefix}</span>
                                    <span class="text-[9px] uppercase tracking-wider font-semibold px-1.5 py-0.2 rounded border ${refTypeBadgeClass}">${refTypeLabel}</span>
                                </div>
                                <span class="text-base text-white font-extrabold leading-tight">${refMovie.title} <span class="text-slate-400 font-normal text-xs">(${refMovie.year || 'Unknown'})</span></span>
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-2.5 w-full sm:w-auto justify-end mt-2 sm:mt-0 items-center">
                            ${cacheId ? `
                            <button onclick="shareWatchlist(${cacheId}, this)" title="${t.shareBtn}" class="flex-1 sm:flex-initial text-slate-400 hover:text-emerald-400 bg-slate-900/60 hover:bg-slate-800/80 border border-slate-700/50 hover:border-emerald-500/30 p-2 rounded-lg text-center transition-all duration-300 flex items-center justify-center shadow-sm" aria-label="${t.shareBtn}">
                                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 10.742l4.628-2.571m0 0a3.001 3.001 0 110 5.658L8.684 13.8a3 3 0 110-3.058z"/></svg>
                            </button>
                            ` : ''}
                            ${refMovie.trailerYtId ? `
                            <button onclick="openTrailer('${refMovie.trailerYtId}', ${JSON.stringify(refMovie.title).replace(/"/g, '&quot;')})" class="flex-1 sm:flex-initial text-[11px] bg-slate-900/60 hover:bg-slate-700/80 text-amber-400 font-bold py-1.5 px-4 rounded-lg text-center transition-all duration-300 border border-amber-500/20 hover:border-amber-500/40 flex items-center justify-center gap-1.5 shadow-sm">
                                <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                <span>Trailer</span>
                            </button>
                            ` : ''}
                            <a id="${refImdbLinkId}" href="${refMovie.imdbId ? `https://www.imdb.com/title/${refMovie.imdbId}/` : `https://www.imdb.com/find?q=${encodeURIComponent(refMovie.title)}`}" target="_blank" class="flex-1 sm:flex-initial text-[11px] bg-slate-900/60 hover:bg-slate-700/80 text-sky-400 font-bold py-1.5 px-4 rounded-lg text-center transition-all duration-300 border border-sky-500/20 hover:border-sky-500/40 flex items-center justify-center gap-1.5 shadow-sm">
                                <svg class="w-3.5 h-3.5 text-sky-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.53c-.26-.81-1-1.4-1.9-1.4h-1v-3c0-.55-.45-1-1-1h-6v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.4z"/></svg>
                                IMDB
                            </a>
                            <button onclick="event.stopPropagation(); window.playMovieDirectly('${btoa(encodeURIComponent(JSON.stringify(refMovie)))}', this);" class="flex-1 sm:flex-initial text-[11px] bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 text-white font-bold py-1.5 px-4 rounded-lg text-center transition-all duration-300 flex items-center justify-center gap-1.5 shadow-md shadow-indigo-950/30 hover:shadow-indigo-500/10">
                                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                                <span>${t.playBtn}</span>
                            </button>
                        </div>
                    </div>
                `;
            }

            // Render Recommendations
            const slicedMovies = movies;
            
            // Auto-detect Display Sizing
            if (slicedMovies.length >= 8) {
                applyDisplayStyle('compact');
            } else {
                applyDisplayStyle('standard');
            }

            slicedMovies.forEach((m, index) => {
                const fallbackArtwork = `https://ui-avatars.com/api/?name=${encodeURIComponent(m.title)}&background=1e293b&color=fff&size=500`;
                const safeFallback = fallbackArtwork.replace(/'/g, "%27");
                const artwork = m.poster ? m.poster : (m.imdbId ? `https://images.metahub.space/poster/medium/${m.imdbId}/img` : fallbackArtwork);
                
                const imgId = `poster-${index}-${Date.now()}`;
                const imdbLinkId = `imdb-link-${index}-${Date.now()}`;
                const refImdbId = m.imdb_id || m.imdbId;
                
                const isSeries = (m.type === 'series' || m.type === 'tv');
                const typeLabel = isSeries ? t.typeSeries : t.typeMovie;
                const typeBadgeClass = isSeries 
                    ? 'bg-purple-500/20 text-purple-400 border-purple-500/30' 
                    : 'bg-sky-500/20 text-sky-400 border-sky-500/30';

                const delay = index * 60;
                const safeTitle = (m.title || '').replace(/"/g, '&quot;');
                
                let safeObjectStr = "";
                let b64Obj = "";
                try { 
                    safeObjectStr = JSON.stringify(m).replace(/"/g, '&quot;'); 
                    b64Obj = btoa(encodeURIComponent(JSON.stringify(m)));
                } catch(e) {}
                
                const card = document.createElement('div');
                card.className = 'movie-card overflow-hidden flex flex-col group h-full bg-slate-800/80 border border-slate-700/50 rounded-2xl w-full sm:w-[calc(50%-1.25rem)] md:w-[calc(33.333%-1.25rem)] lg:w-[calc(20%-1.25rem)] max-w-sm mx-auto';
                card.style.animation = `fadeInUp 0.5s ease forwards ${delay}ms`;
                card.style.opacity = '0';
                
                card.innerHTML = `
                    <div class="relative overflow-hidden aspect-[2/3] bg-slate-800 flex items-center justify-center cursor-pointer" onclick="window.openDetailsModal('${b64Obj}')">
                        <img loading=\lazy\ decoding=\async\ id="${imgId}" src="${artwork}" alt="${(m.title || '').replace(/"/g, '&quot;')}" class="w-full h-full object-cover transition-all duration-700 opacity-0 group-hover:scale-105" loading="lazy" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='${safeFallback}'; this.classList.remove('opacity-0')">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-90"></div>
                        <div class="absolute top-2 left-2 backdrop-blur-md text-[9px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded border ${typeBadgeClass}">
                            ${typeLabel}
                        </div>
                        <div class="absolute top-2 right-2 bg-slate-900/80 backdrop-blur-md text-amber-400 text-xs font-semibold px-2 py-1 rounded flex items-center gap-1 border border-slate-700/50">
                            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg> ${m.rating || m.imdbRating || 'N/A'}
                        </div>
                        <h3 class="absolute bottom-3 left-4 right-4 text-lg font-bold leading-tight text-white drop-shadow-md">
                            ${m.title} <span class="text-slate-300 font-normal text-xs">(${m.year || 'N/A'})</span>
                        </h3>
                    </div>
                    <div class="p-4 flex-1 flex flex-col">
                        <div class="flex flex-wrap gap-1.5 mb-2.5">
                            <span class="text-[9px] uppercase tracking-wider font-semibold text-sky-400 bg-sky-400/10 px-1.5 py-0.5 rounded border border-sky-400/20">${m.duration || 'N/A'}</span>
                            <span class="text-[9px] uppercase tracking-wider font-semibold text-indigo-400 bg-indigo-400/10 px-1.5 py-0.5 rounded border border-indigo-400/20 line-clamp-1">${m.category || 'N/A'}</span>
                        </div>
                        <p class="text-xs text-slate-300 leading-relaxed flex-1 line-clamp-4">${m.description}</p>
                        <div class="mt-auto pt-3 flex flex-col gap-2">
                            <button onclick="event.stopPropagation(); window.playMovieDirectly('${b64Obj}', this);" class="w-full text-xs bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 text-white font-bold py-2 px-3 rounded-lg text-center transition-all duration-300 flex items-center justify-center gap-1.5 shadow-md shadow-indigo-950/50 hover:shadow-indigo-500/10">
                                <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                                <span>${t.playBtn}</span>
                            </button>
                            <div class="flex gap-2">
                                <a id="${imdbLinkId}" href="${refImdbId ? `https://www.imdb.com/title/${refImdbId}/` : `https://www.imdb.com/find?q=${encodeURIComponent(m.originalTitle || m.title)}`}" target="_blank" class="flex-1 text-[10px] bg-slate-800/80 hover:bg-slate-700 text-sky-400 font-semibold py-1.5 px-1.5 rounded-lg text-center transition-colors border border-slate-700/60 flex items-center justify-center gap-1">IMDB</a>
                                ${m.trailerYtId ? `
                                <button onclick="openTrailer('${m.trailerYtId}', ${JSON.stringify(m.title).replace(/"/g, '&quot;')})" class="flex-1 text-[10px] bg-slate-800/80 hover:bg-slate-700 text-amber-400 font-semibold py-1.5 px-1.5 rounded-lg text-center transition-colors border border-slate-700/60 flex items-center justify-center gap-1">
                                    <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                    Trailer
                                </button>
                                ` : ''}
                                ${isLoggedIn && !isPublicShareMode ? `
                                <button onclick="toggleWatchlist(this, ${JSON.stringify(m).replace(/"/g, '&quot;')})" class="watchlist-btn px-3 rounded-lg transition-colors border flex items-center justify-center ${inWatchlist(m.title, m.year) ? 'text-emerald-400 bg-emerald-950/40 border-emerald-500/40' : 'text-slate-400 bg-slate-800/80 hover:bg-slate-700 border-slate-700/60 hover:text-white'}">
                                    <svg class="w-3.5 h-3.5" fill="${inWatchlist(m.title, m.year) ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                                </button>
                                ` : ''}
                            </div>
                        </div>
                    </div>
                `;
                resultsContainer.appendChild(card);
            });
            
            setTimeout(() => {
                referenceMovieContainer.style.opacity = '1';
                resultsContainer.style.opacity = '1';
                
                // Show/hide the "Load More" button container based on hasMoreResults
                if (hasMoreResults) {
                    loadMoreContainer.classList.remove('hidden');
                    loadMoreContainer.classList.remove('hidden-section');
                    setTimeout(() => {
                        loadMoreContainer.style.opacity = '1';
                    }, 50);
                } else {
                    loadMoreContainer.classList.add('hidden');
                    loadMoreContainer.classList.add('hidden-section');
                    loadMoreContainer.style.opacity = '0';
                }
            }, 50);
        }

        // Persistent Watchlist Functions
        function inWatchlist(title, year) {
            return userWatchlist.some(m => m.title === title && parseInt(m.year) === parseInt(year));
        }

        async function toggleWatchlist(btn, m) {
            const isFav = inWatchlist(m.title, m.year);
            const url = isFav ? '/api/watchlist/remove' : '/api/watchlist/add';
            
            try {
                const res = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        imdb_id: m.imdbId || m.imdb_id,
                        title: m.title,
                        original_title: m.originalTitle || m.original_title || m.title,
                        year: m.year,
                        type: m.type || 'movie',
                        rating: m.imdbRating || m.rating,
                        duration: m.duration,
                        category: m.category,
                        description: m.description,
                        trailer_yt_id: m.trailerYtId || m.trailer_yt_id || null,
                        poster: m.poster || null
                    })
                });
                
                if (res.status === 401) {
                    openModal('login');
                    return;
                }
                
                const data = await res.json();
                if (data.success) {
                    if (isFav) {
                        userWatchlist = userWatchlist.filter(item => !(item.title === m.title && parseInt(item.year) === parseInt(m.year)));
                    } else {
                        userWatchlist.push(m);
                    }
                    
                    updateWatchlistButton(btn, !isFav);
                    
                    if (activeTab === 'watchlist') {
                        renderWatchlistGrid();
                    }
                }
            } catch(e) {
                console.error("Failed to toggle watchlist:", e);
            }
        }

        function updateWatchlistButton(btn, isSaved) {
            if (isSaved) {
                btn.className = 'watchlist-btn px-3 rounded transition-colors border flex items-center justify-center text-emerald-400 bg-emerald-950/40 border-emerald-500/40';
                btn.innerHTML = `<svg class="w-3.5 h-3.5" fill="currentColor" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>`;
            } else {
                btn.className = 'watchlist-btn px-3 rounded transition-colors border flex items-center justify-center text-slate-400 bg-slate-800/80 hover:bg-slate-700 border-slate-700 hover:text-white';
                btn.innerHTML = `<svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>`;
            }
        }

        async function loadUserWatchlist() {
            if (!isLoggedIn) return;
            try {
                const res = await fetch('/api/watchlist', { credentials: 'include' });
                const data = await res.json();
                if (data.success && Array.isArray(data.watchlist)) {
                    userWatchlist = data.watchlist;
                }
            } catch (e) {
                console.error("Failed to load watchlist", e);
            }
        }

        async function forceRefreshWatchlist() {
            if (!isLoggedIn) return;
            try {
                const res = await fetch('/api/watchlist', { credentials: 'include' });
                const data = await res.json();
                if (data.success && Array.isArray(data.watchlist)) {
                    userWatchlist = data.watchlist;
                    loadFrontpageWatchlist(); // Update frontpage if visible
                }
            } catch (e) {
                console.error("Failed to load watchlist", e);
            }
        }

        function loadFrontpageWatchlist() {
            const grid = document.getElementById('frontpage-watchlist-grid');
            if (!grid) return;
            
            if (userWatchlist.length === 0) {
                grid.innerHTML = '<p class="text-xs text-slate-500 col-span-full">Your watchlist is empty. Search for a movie to start adding!</p>';
                return;
            }
            
            // Show up to 5 most recent
            const recent = [...userWatchlist].reverse().slice(0, 5);
            
            grid.innerHTML = recent.map((m, i) => {
                const posterUrl = m.poster || `https://images.metahub.space/poster/medium/${m.imdbId || m.imdb_id}/img`;
                return `
                    <div class="relative w-full aspect-[2/3] rounded-lg overflow-hidden border border-slate-700/50 shadow-md group cursor-pointer animate-fade-in-up" style="animation-delay: ${i * 50}ms" onclick="searchMovie('${(m.imdbId || m.imdb_id).replace(/'/g, "\\'")}', true)">
                        <img loading=" lazy\ decoding=\async\ src="${posterUrl}" class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105" onerror="this.src='/placeholder.jpg'">
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/20 to-transparent opacity-80 group-hover:opacity-100 transition-opacity"></div>
                        <div class="absolute bottom-0 left-0 right-0 p-2 transform translate-y-1 group-hover:translate-y-0 transition-transform">
                            <p class="text-[10px] font-bold text-white truncate drop-shadow-md">${m.title}</p>
                            <div class="flex items-center gap-1 text-[9px] text-sky-300 font-semibold mt-0.5">
                                <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                                ${m.rating || m.imdbRating || 'N/A'}
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }


        function toggleWatchlistTab() {
            if (!isLoggedIn) {
                openModal('login');
                return;
            }
            
            if (activeTab === 'home') {
                activeTab = 'watchlist';
                showWatchlistTab();
            } else {
                activeTab = 'home';
                goHome();
            }
        }

        function showWatchlistTab(pushState = true) {
            activeTab = 'watchlist';
            if (pushState) {
                if (!window.history.state) {
                    window.history.replaceState({ view: 'home' }, '', '/');
                }
                window.history.pushState({ view: 'watchlist' }, '', '/?tab=watchlist');
            }
            const hideIds = ['hero-header', 'features-section', 'dynamic-bg', 'search-container', 'reference-movie-container', 'frontpage-watchlist-section'];
            const showIds = ['watchlist-header-container', 'results-container'];
            
            transitionTo(hideIds, showIds, async () => {
                document.getElementById('watchlist-header-title').textContent = dict[currentLang].navWatchlist;
                if (isLoggedIn && (!userWatchlist || userWatchlist.length === 0)) {
                    await loadUserWatchlist();
                }
                renderWatchlistGrid();
                setLoginState(isLoggedIn, currentUser);
            });
        }

        function renderWatchlistGrid() {
            console.log("Entering renderWatchlistGrid");
            resultsContainer.style.opacity = '1';
            resultsContainer.innerHTML = '';
            const t = dict[currentLang];
            console.log("Dict for currentLang:", !!t);
            
            console.log("Checking if empty:", userWatchlist.length);
            if (userWatchlist.length === 0) {
                const emptyState = document.createElement('div');
                emptyState.className = 'col-span-full flex flex-col items-center justify-center py-20 animate-fade-in-up';
                        emptyState.innerHTML = `
                        <div class="bg-slate-800/40 p-4 rounded-full mb-4 border border-slate-700/50">
                            <svg class="w-10 h-10 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                        </div>
                        <p class="text-slate-400 text-sm text-center max-w-sm mb-6">${t.watchlistEmpty}</p>
                        <button onclick="forceRefreshWatchlist()" class="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-sky-400 font-semibold rounded-lg border border-slate-700/60 transition-colors flex items-center gap-2">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
                            Atualizar Lista
                        </button>
                `;
                resultsContainer.appendChild(emptyState);
                return;
            }
            
            console.log("Starting loop over userWatchlist");
            userWatchlist.forEach((m, index) => {
                console.log("Loop iteration", index, m.title);
                try {
                    const fallbackArtwork = `https://ui-avatars.com/api/?name=${encodeURIComponent(m.title)}&background=1e293b&color=fff&size=500`;
                    const safeFallback = fallbackArtwork.replace(/'/g, "%27");
                    const imdbId = m.imdb_id || m.imdbId;
                    const rating = m.rating || m.imdbRating || m.imdb_rating || 'N/A';
                    const originalTitle = m.original_title || m.originalTitle || m.title;
                    const trailerYtId = m.trailer_yt_id || m.trailerYtId;
                    const artwork = m.poster ? m.poster : (imdbId ? `https://images.metahub.space/poster/medium/${imdbId}/img` : fallbackArtwork);
                    
                    const card = document.createElement('div');
                    card.className = 'movie-card overflow-hidden flex flex-col group h-full bg-slate-800/80 border border-slate-700/50 rounded-2xl w-full sm:w-[calc(50%-1.25rem)] md:w-[calc(33.333%-1.25rem)] lg:w-[calc(20%-1.25rem)] max-w-sm mx-auto';
                    card.style.animation = `fadeInUp 0.5s ease forwards ${index * 60}ms`;
                    card.style.opacity = '0';
                    
                    const isSeries = (m.type === 'series' || m.type === 'tv');
                    const typeLabel = isSeries ? t.typeSeries : t.typeMovie;
                    const typeBadgeClass = isSeries 
                        ? 'bg-purple-500/20 text-purple-400 border-purple-500/30' 
                        : 'bg-sky-500/20 text-sky-400 border-sky-500/30';
                    
                    const safeDescription = (m.description || '').replace(/"/g, '&quot;');
                    
                    let safeObjectStr = "";
                    let b64Obj = "";
                    try { 
                        safeObjectStr = JSON.stringify(m).replace(/"/g, '&quot;'); 
                        b64Obj = btoa(encodeURIComponent(JSON.stringify(m)));
                    } catch(e) {}
                    let safeTitleStr = "";
                    try { safeTitleStr = JSON.stringify(m.title).replace(/"/g, '&quot;'); } catch(e) {}

                    card.innerHTML = `
                        <div class="relative overflow-hidden aspect-[2/3] bg-slate-800 flex items-center justify-center cursor-pointer" onclick="window.openDetailsModal('${b64Obj}')">
                            <img loading=" lazy\ decoding=\async\ src="${artwork}" alt="${(m.title || '').replace(/"/g, '&quot;')}" class="w-full h-full object-cover transition-all duration-700 opacity-0 group-hover:scale-105" loading="lazy" onload="this.classList.remove('opacity-0')" onerror="this.onerror=null; this.src='${safeFallback}'; this.classList.remove('opacity-0')">
                            <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/20 to-transparent opacity-90"></div>
                            <div class="absolute top-2 left-2 backdrop-blur-md text-[9px] uppercase tracking-wider font-semibold px-2 py-0.5 rounded border ${typeBadgeClass}">
                                ${typeLabel}
                            </div>
                            <div class="absolute top-2 right-2 bg-slate-900/80 backdrop-blur-md text-amber-400 text-xs font-semibold px-2 py-1 rounded flex items-center gap-1 border border-slate-700/50">
                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg> ${rating}
                            </div>
                            <h3 class="absolute bottom-3 left-4 right-4 text-lg font-bold leading-tight text-white drop-shadow-md">
                                ${m.title} <span class="text-slate-300 font-normal text-xs">(${m.year || 'N/A'})</span>
                            </h3>
                        </div>
                        <div class="p-4 flex-1 flex flex-col">
                            <div class="flex flex-wrap gap-1.5 mb-2.5">
                                <span class="text-[9px] uppercase tracking-wider font-semibold text-sky-400 bg-sky-400/10 px-1.5 py-0.5 rounded border border-sky-400/20">${m.duration || 'N/A'}</span>
                                <span class="text-[9px] uppercase tracking-wider font-semibold text-indigo-400 bg-indigo-400/10 px-1.5 py-0.5 rounded border border-indigo-400/20 line-clamp-1">${m.category || 'N/A'}</span>
                            </div>
                            <p class="text-xs text-slate-300 leading-relaxed flex-1 line-clamp-4">${safeDescription}</p>
                            <div class="mt-auto pt-3 flex flex-col gap-2">
                                <button onclick="event.stopPropagation(); window.playMovieDirectly('${b64Obj}', this);" class="w-full text-xs bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 text-white font-bold py-2 px-3 rounded-lg text-center transition-all duration-300 flex items-center justify-center gap-1.5 shadow-md shadow-indigo-950/50 hover:shadow-indigo-500/10">
                                    <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg>
                                    <span>${t.playBtn}</span>
                                </button>
                                <div class="flex gap-2">
                                    <a href="${imdbId ? `https://www.imdb.com/title/${imdbId}/` : `https://www.imdb.com/find?q=${encodeURIComponent(originalTitle)}`}" target="_blank" class="flex-1 text-[10px] bg-slate-800/80 hover:bg-slate-700 text-sky-400 font-semibold py-1.5 px-1.5 rounded-lg text-center transition-colors border border-slate-700/60 flex items-center justify-center gap-1">IMDB</a>
                                    ${trailerYtId ? `
                                    <button onclick="openTrailer('${trailerYtId}', ${safeTitleStr})" class="flex-1 text-[10px] bg-slate-800/80 hover:bg-slate-700 text-amber-400 font-semibold py-1.5 px-1.5 rounded-lg text-center transition-colors border border-slate-700/60 flex items-center justify-center gap-1">
                                        <svg class="w-3.5 h-3.5 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
                                        Trailer
                                    </button>
                                    ` : ''}
                                    <button onclick="toggleWatchlist(this, ${safeObjectStr})" class="watchlist-btn px-3 rounded-lg transition-colors border flex items-center justify-center text-emerald-400 bg-emerald-950/40 border-emerald-500/40">
                                        <svg class="w-3.5 h-3.5" fill="currentColor" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                                    </button>
                                </div>
                            </div>
                        </div>
                    `;
                    resultsContainer.appendChild(card);
                } catch(e) {
                    fetch('/api/log', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ event: 'WATCHLIST_RENDER_ERROR', name: e.name, message: e.message, stack: e.stack }) });
                    console.error("Failed to render movie card", m, e);
                    const errCard = document.createElement('div');
                    errCard.className = 'glass-panel p-4 bg-red-900/40 text-red-200 border-red-500/50';
                    errCard.textContent = `Error rendering ${m.title}: ${e.message}`;
                    resultsContainer.appendChild(errCard);
                }
            });
        }

        // Movie Details Modal Functions
        window.playMovieDirectly = async function(b64, btnElement) {
            if (!b64) return;
            if (btnElement) {
                btnElement.dataset.originalHtml = btnElement.innerHTML;
                btnElement.innerHTML = `<svg class="animate-spin h-3.5 w-3.5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> <span>Loading...</span>`;
                btnElement.classList.add('opacity-75', 'cursor-not-allowed');
            }
            
            const m = JSON.parse(decodeURIComponent(atob(b64)));
            const title = m.title || '';
            const originalTitle = m.originalTitle || m.original_title || title;
            const year = m.year || '';
            const type = m.type || 'movie';
            let imdbId = m.imdbId || m.imdb_id;
            let tmdbId = m.tmdbId || null;
            
            if (!imdbId) {
                try {
                    const searchRes = await fetch(`/api/proxy/catalog/${type === 'series' || type === 'tv' ? 'series' : 'movie'}/search=${encodeURIComponent(originalTitle || title)}`);
                    if (searchRes.ok) {
                        const searchData = await searchRes.json();
                        if (searchData.metas && searchData.metas.length > 0) {
                            const match = searchData.metas.find(meta => meta.year == year) || searchData.metas[0];
                            imdbId = match.imdb_id || match.id;
                        }
                    }
                } catch(e) {
                    console.error("Error finding imdbId for play:", e);
                }
            }
            
            if (!tmdbId && imdbId) {
                try {
                    const metaRes = await fetch(`/api/proxy/meta/${type === 'series' || type === 'tv' ? 'series' : 'movie'}/${imdbId}`);
                    if (metaRes.ok) {
                        const metaData = await metaRes.json();
                        if (metaData && metaData.meta && metaData.meta.moviedb_id) {
                            tmdbId = metaData.meta.moviedb_id;
                        }
                    }
                } catch(e) {
                    console.error("Error fetching tmdbid:", e);
                }
            }
            
            if (btnElement && btnElement.dataset.originalHtml) {
                btnElement.innerHTML = btnElement.dataset.originalHtml;
                btnElement.classList.remove('opacity-75', 'cursor-not-allowed');
            }
            
            const urlType = (type === 'series' || type === 'tv') ? 'tv' : 'movie';
            const slug = (originalTitle || title).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
            const watchUrl = tmdbId 
                ? `https://flixmomo.app/${urlType}/${tmdbId}/${slug}` 
                : `https://flixmomo.app/search?q=${encodeURIComponent(originalTitle || title)}`;
            
            window.open(watchUrl, '_blank');
        };

        window.openDetailsModal = async function(b64) {
            if (!b64) return;
            const m = JSON.parse(decodeURIComponent(atob(b64)));
            const title = m.title || '';
            const originalTitle = m.originalTitle || m.original_title || title;
            const type = m.type || 'movie';
            const year = m.year || '';
            const fallbackPlot = m.description || '';
            const fallbackRating = m.rating || m.imdbRating || m.imdb_rating || '';
            const fallbackDuration = m.duration || '';
            const fallbackGenres = m.category || m.genre || '';
            
            const modal = document.getElementById('details-modal');
            const loading = document.getElementById('details-loading');
            const content = document.getElementById('details-content');
            
            modal.classList.remove('hidden');
            loading.classList.remove('hidden');
            content.classList.add('hidden');

            try {
                // Step 1: Find IMDB ID
                let imdbId = null;
                const searchRes = await fetch(`/api/proxy/catalog/${type || 'movie'}/search=${encodeURIComponent(originalTitle || title)}`);
                if (searchRes.ok) {
                    const searchData = await searchRes.json();
                    if (searchData.metas && searchData.metas.length > 0) {
                        const match = searchData.metas.find(m => m.year == year) || searchData.metas[0];
                        imdbId = match.imdb_id || match.id;
                    }
                }

                // Step 2: Fetch Details
                let meta = null;
                if (imdbId) {
                    const metaRes = await fetch(`/api/proxy/meta/${type || 'movie'}/${imdbId}`);
                    if (metaRes.ok) {
                        const metaData = await metaRes.json();
                        meta = metaData.meta;
                    }
                }

                // Populate UI
                document.getElementById('details-title').textContent = title;
                document.getElementById('details-year').textContent = year || (meta ? meta.year : 'N/A');
                document.getElementById('details-rating-val').textContent = (meta && meta.imdbRating) ? meta.imdbRating : (fallbackRating || 'N/A');
                document.getElementById('details-duration').textContent = (meta && meta.runtime) ? meta.runtime : (fallbackDuration || 'N/A');
                document.getElementById('details-type').textContent = (type === 'series' || type === 'tv') ? (currentLang === 'pt' ? 'Série' : 'Series') : (currentLang === 'pt' ? 'Filme' : 'Movie');
                document.getElementById('details-plot').textContent = (meta && meta.description) ? meta.description : (fallbackPlot || 'No synopsis available.');
                
                // Poster & Background
                const posterEl = document.getElementById('details-poster');
                const bgEl = document.getElementById('details-bg');
                
                const posterUrl = meta && meta.poster ? meta.poster : (imdbId ? `https://images.metahub.space/poster/medium/${imdbId}/img` : '');
                posterEl.src = posterUrl;
                
                const bgUrl = meta && meta.background ? meta.background : posterUrl;
                bgEl.style.backgroundImage = `url('${bgUrl}')`;

                // Cast & Director
                document.getElementById('details-director').textContent = meta && meta.director ? meta.director.join(', ') : 'N/A';
                const castContainer = document.getElementById('details-cast');
                castContainer.innerHTML = '';
                if (meta && meta.cast && meta.cast.length > 0) {
                    meta.cast.slice(0, 5).forEach(c => {
                        const p = document.createElement('p');
                        p.textContent = c;
                        castContainer.appendChild(p);
                    });
                } else {
                    castContainer.textContent = 'N/A';
                }

                // Genres
                const genresContainer = document.getElementById('details-genres');
                genresContainer.innerHTML = '';
                const genresList = (meta && meta.genre) ? meta.genre : (fallbackGenres ? fallbackGenres.split(',') : []);
                genresList.forEach(g => {
                    const span = document.createElement('span');
                    span.className = 'px-2 py-0.5 rounded text-xs font-medium bg-slate-800/80 border border-slate-700/50 text-slate-300';
                    span.textContent = g.trim();
                    genresContainer.appendChild(span);
                });

                // Buttons
                const btnsContainer = document.getElementById('details-buttons');
                btnsContainer.innerHTML = '';
                
                const ytTrailer = meta && meta.trailerStreams && meta.trailerStreams.length > 0 ? meta.trailerStreams[0].ytId : (meta && meta.trailers && meta.trailers.length > 0 ? meta.trailers[0].source : null);
                
                if (ytTrailer) {
                    btnsContainer.innerHTML += `
                        <button onclick="openTrailer('${ytTrailer}', '${title.replace(/'/g, "\\'")}')" class="bg-amber-500 hover:bg-amber-400 text-slate-900 font-bold py-2.5 px-6 rounded-lg transition-colors flex items-center gap-2 shadow-lg shadow-amber-500/20">
                            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg> Trailer
                        </button>
                    `;
                }
                
                const resolvedTmdbId = (meta && meta.moviedb_id) ? meta.moviedb_id : m.tmdbId;
                const urlType = (type === 'series' || type === 'tv') ? 'tv' : 'movie';
                const slug = (originalTitle || title).toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
                const watchUrl = resolvedTmdbId 
                    ? `https://flixmomo.app/${urlType}/${resolvedTmdbId}/${slug}` 
                    : `https://flixmomo.app/search?q=${encodeURIComponent(originalTitle || title)}`;
                
                btnsContainer.innerHTML += `
                    <a href="${watchUrl}" target="_blank" class="bg-sky-600 hover:bg-sky-500 text-white font-bold py-2.5 px-6 rounded-lg transition-colors flex items-center gap-2 shadow-lg shadow-sky-600/20">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/></svg> Watch Now
                    </a>
                `;

            } catch (err) {
                console.error("Details Modal Error:", err);
            } finally {
                loading.classList.add('hidden');
                content.classList.remove('hidden');
            }
        }

        window.closeDetailsModal = function() {
            document.getElementById('details-modal').classList.add('hidden');
            document.getElementById('details-bg').style.backgroundImage = "url('')";
        }

        // YouTube Trailer Modal Functions
        function openTrailer(ytId, title = '') {
            const trailerModal = document.getElementById('trailer-modal');
            const container = document.getElementById('trailer-player-container');
            if (!trailerModal || !container || !ytId) return;

            trailerModal.classList.add('active');
            
            // Clean player container and set placeholder loading state
            container.innerHTML = `<div id="yt-player-placeholder" class="w-full h-full rounded-lg bg-slate-950 flex items-center justify-center"><div class="loader"></div></div>`;

            function initPlayer() {
                try {
                    ytPlayer = new YT.Player('yt-player-placeholder', {
                        height: '100%',
                        width: '100%',
                        videoId: ytId,
                        playerVars: {
                            'autoplay': 1,
                            'playsinline': 1,
                            'rel': 0,
                            'modestbranding': 1
                        },
                        events: {
                            'onError': function(e) {
                                console.warn("YouTube Player API Error:", e.data);
                                // Error codes: 2 (invalid parameters), 5 (HTML5 error), 100 (private/removed), 101/150 (restricted/not embeddable)
                                showTrailerFallback(container, title);
                            }
                        }
                    });
                } catch (err) {
                    console.error("Failed to initialize YouTube Player:", err);
                    fallbackIframe(container, ytId);
                }
            }

            if (typeof YT !== 'undefined' && YT.Player) {
                initPlayer();
            } else {
                // If the YouTube API is not loaded yet, poll for up to 3 seconds before falling back
                let attempts = 0;
                const interval = setInterval(() => {
                    attempts++;
                    if (typeof YT !== 'undefined' && YT.Player) {
                        clearInterval(interval);
                        initPlayer();
                    } else if (attempts > 30) {
                        clearInterval(interval);
                        fallbackIframe(container, ytId);
                    }
                }, 100);
            }
        }
        
        function fallbackIframe(container, ytId) {
            container.innerHTML = `<iframe class="w-full h-full rounded-lg" src="https://www.youtube.com/embed/${ytId}?autoplay=1" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>`;
        }

        function showTrailerFallback(container, title) {
            const t = dict[currentLang];
            container.innerHTML = `
                <div class="w-full h-full rounded-lg bg-slate-950 flex flex-col items-center justify-center p-6 text-center font-sans">
                    <div class="bg-red-500/10 p-3 rounded-full mb-4 border border-red-500/20 shadow-[0_0_15px_rgba(239,68,68,0.15)]">
                        <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                    </div>
                    <h4 class="text-lg font-bold text-white mb-2">${t.ytErrorTitle}</h4>
                    <p class="text-sm text-slate-400 max-w-md mb-6">${t.ytErrorMsg}</p>
                    <a href="https://www.youtube.com/results?search_query=${encodeURIComponent(title + ' trailer')}" target="_blank" class="bg-sky-600 hover:bg-sky-500 text-white text-xs font-bold py-2.5 px-6 rounded-lg transition-all shadow-md flex items-center gap-2">
                        <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M23.498 6.163a3.003 3.003 0 00-2.11-2.11C19.518 3.545 12 3.545 12 3.545s-7.518 0-9.388.508a3.003 3.003 0 00-2.11 2.11C0 8.033 0 12 0 12s0 3.967.502 5.837a3.003 3.003 0 002.11 2.11c1.87.508 9.388.508 9.388.508s7.518 0 9.388-.508a3.003 3.003 0 002.11-2.11C24 15.967 24 12 24 12s0-3.967-.502-5.837zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                        <span>${t.ytErrorBtn}</span>
                    </a>
                </div>
            `;
        }
        
        function closeTrailer() {
            const trailerModal = document.getElementById('trailer-modal');
            const container = document.getElementById('trailer-player-container');
            if (trailerModal) {
                if (ytPlayer) {
                    try { ytPlayer.destroy(); } catch(e){}
                    ytPlayer = null;
                }
                if (container) {
                    container.innerHTML = '';
                }
                trailerModal.classList.remove('active');
            }
        }

        // Social Watchlist Sharing Functions
        async function shareWatchlist(cacheId, btn) {
            const t = dict[currentLang];
            const shareUrl = `${window.location.origin}/?share=${cacheId}`;
            
            let copied = false;
            try {
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    await navigator.clipboard.writeText(shareUrl);
                    copied = true;
                }
            } catch (err) {
                console.warn("navigator.clipboard failed, attempting fallback...", err);
            }

            if (!copied) {
                try {
                    const textArea = document.createElement("textarea");
                    textArea.value = shareUrl;
                    textArea.style.top = "0";
                    textArea.style.left = "0";
                    textArea.style.position = "fixed";
                    textArea.style.opacity = "0";
                    document.body.appendChild(textArea);
                    textArea.focus();
                    textArea.select();
                    const successful = document.execCommand('copy');
                    document.body.removeChild(textArea);
                    if (successful) {
                        copied = true;
                    }
                } catch (err) {
                    console.error("Fallback copy failed:", err);
                }
            }

            if (copied) {
                showToast(t.shareToast);
            } else {
                showToast(currentLang === 'pt' ? "Não foi possível copiar o link automaticamente." : "Could not copy link automatically.");
            }
        }
        
        function showToast(message) {
            let toast = document.getElementById('share-toast');
            if (!toast) {
                toast = document.createElement('div');
                toast.id = 'share-toast';
                toast.className = 'fixed bottom-5 right-5 z-50 glass-panel bg-emerald-950/90 border-emerald-500/40 text-emerald-300 text-xs font-semibold px-4 py-3 rounded-lg shadow-xl pointer-events-none transition-all duration-300 opacity-0 transform translate-y-2';
                document.body.appendChild(toast);
            }
            toast.textContent = message;
            toast.style.opacity = '1';
            toast.style.transform = 'translateY(0)';
            
            setTimeout(() => {
                toast.style.opacity = '0';
                toast.style.transform = 'translateY(8px)';
            }, 3000);
        }

        async function handleSharedList() {
            const params = new URLSearchParams(window.location.search);
            const shareId = params.get('share');
            if (!shareId) return false;
            
            if (!window.history.state) {
                window.history.replaceState({ view: 'home' }, '', '/');
                window.history.pushState({ view: 'share', id: shareId }, '', '?share=' + shareId);
            }
            
            isPublicShareMode = true;
            
            heroHeader.classList.add('hidden-section');
            featuresSection.classList.add('hidden-section');
            document.getElementById('dynamic-bg').classList.add('hidden-section');
            searchContainer.classList.add('hidden-section');
            referenceMovieContainer.classList.remove('hidden-section');
            resultsContainer.classList.remove('hidden-section');
            document.getElementById('watchlist-header-container').classList.add('hidden-section');
            
            const t = dict[currentLang];
            let shareHeader = document.getElementById('share-header');
            if (!shareHeader) {
                shareHeader = document.createElement('div');
                shareHeader.id = 'share-header';
                shareHeader.className = 'w-full max-w-6xl mb-6 text-left flex justify-between items-center flex-wrap gap-4 animate-fade-in-up';
                resultsContainer.parentNode.insertBefore(shareHeader, referenceMovieContainer);
            }
            
            
            heroHeader.innerHTML = `
                <h2 class="text-3xl font-extrabold text-white flex items-center gap-2.5">
                    <svg class="w-8 h-8 text-sky-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
                    <span>${t.shareHeading}</span>
                </h2>
                <a href="/" class="bg-sky-600 hover:bg-sky-500 text-white text-xs font-bold px-4 py-2.5 rounded-lg transition-all shadow-md">
                    ${t.shareCTA}
                </a>
            `;
            
            resultsContainer.innerHTML = `
                <div class="col-span-full flex flex-col items-center justify-center py-20">
                    <div class="w-12 h-12 border-4 border-slate-800 border-t-sky-500 rounded-full animate-spin"></div>
                </div>
            `;
            resultsContainer.style.opacity = '1';
            
            try {
                const res = await fetch(`/api/share/${shareId}`);
                const data = await res.json();
                if (data.success) {
                    renderMovies(data.referenceMovie, data.recommendations, shareId);
                } else {
                    showError("Watchlist not found or expired.");
                }
            } catch (e) {
                showError("Failed to fetch shared curation.");
            }
            
            return true;
        }

        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeInUp {
                from { opacity: 0; transform: translateY(15px); }
                to { opacity: 1; transform: translateY(0); }
            }
            .animate-fade-in-up {
                animation: fadeInUp 0.5s cubic-bezier(0.25, 0.8, 0.25, 1) forwards;
            }
        `;
        document.head.appendChild(style);

        const contactModal = document.getElementById('contact-modal');
        function openLegalModal(id) {
            const m = document.getElementById(id);
            if(m) {
                m.classList.remove('hidden');
                setTimeout(() => {
                    m.classList.remove('opacity-0');
                    const inner = m.querySelector('.transform');
                    if(inner) inner.classList.remove('scale-95');
                }, 10);
            }
        }
        function closeLegalModal(id) {
            const m = document.getElementById(id);
            if(m) {
                m.classList.add('opacity-0');
                const inner = m.querySelector('.transform');
                if(inner) inner.classList.add('scale-95');
                setTimeout(() => m.classList.add('hidden'), 300);
            }
        }

        function openContactModal() {
            if(contactModal) {
                contactModal.classList.remove('hidden');
                setTimeout(() => contactModal.classList.add('active'), 10);
            }
        }
        function closeContactModal() {
            if(contactModal) {
                contactModal.classList.remove('active');
                setTimeout(() => contactModal.classList.add('hidden'), 300);
            }
        }
        // Cookie Banner Logic
        function acceptCookies() {
            localStorage.setItem('cookieConsent', 'true');
            const banner = document.getElementById('cookie-banner');
            if (banner) banner.classList.add('translate-y-full');
        }

        window.addEventListener('DOMContentLoaded', () => {
            if (!localStorage.getItem('cookieConsent')) {
                const banner = document.getElementById('cookie-banner');
                if (banner) {
                    setTimeout(() => {
                        banner.classList.remove('translate-y-full');
                    }, 1000);
                }
            }
            
            const urlParams = new URLSearchParams(window.location.search);
            const resetToken = urlParams.get('reset');
            if (resetToken) {
                window.history.replaceState({}, document.title, "/");
                openResetPasswordModal(resetToken);
            }
        });

        // Modals logic for password
        const forgotModal = document.getElementById('forgot-password-modal');
        function openForgotPasswordModal() {
            const authMod = document.getElementById('auth-modal');
            if (authMod) authMod.classList.remove('active');
            if (forgotModal) {
                forgotModal.classList.remove('hidden');
                setTimeout(() => {
                    forgotModal.classList.remove('opacity-0');
                    forgotModal.querySelector('div').classList.remove('scale-95');
                }, 10);
            }
        }
        function closeForgotPasswordModal() {
            if (forgotModal) {
                forgotModal.classList.add('opacity-0');
                forgotModal.querySelector('div').classList.add('scale-95');
                setTimeout(() => forgotModal.classList.add('hidden'), 300);
            }
        }

        let currentResetToken = null;
        const resetModal = document.getElementById('reset-password-modal');
        function openResetPasswordModal(token) {
            currentResetToken = token;
            if (resetModal) {
                resetModal.classList.remove('hidden');
                setTimeout(() => {
                    resetModal.classList.remove('opacity-0');
                    resetModal.querySelector('div').classList.remove('scale-95');
                }, 10);
            }
        }
        function closeResetPasswordModal() {
            if (resetModal) {
                resetModal.classList.add('opacity-0');
                resetModal.querySelector('div').classList.add('scale-95');
                setTimeout(() => resetModal.classList.add('hidden'), 300);
            }
        }

        async function handleForgotPassword(e) {
            e.preventDefault();
            const email = document.getElementById('forgot-email').value;
            const btn = document.getElementById('forgot-btn');
            const err = document.getElementById('forgot-error');
            const suc = document.getElementById('forgot-success');
            
            btn.innerHTML = `<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>`;
            err.classList.add('hidden');
            suc.classList.add('hidden');
            
            try {
                const res = await fetch('/api/auth/forgot-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: email, lang: currentLang || 'pt' })
                });
                const data = await res.json();
                
                if (res.ok && data.success) {
                    suc.textContent = data.message;
                    suc.classList.remove('hidden');
                    document.getElementById('forgot-email').value = '';
                } else {
                    err.textContent = data.error || 'Erro a processar.';
                    err.classList.remove('hidden');
                }
            } catch(error) {
                err.textContent = 'Erro de rede.';
                err.classList.remove('hidden');
            }
            btn.innerHTML = `<span>Enviar Link</span>`;
        }

        async function handleResetPassword(e) {
            e.preventDefault();
            const pass = document.getElementById('reset-new-pass').value;
            const btn = document.getElementById('reset-btn');
            const err = document.getElementById('reset-error');
            const suc = document.getElementById('reset-success');
            
            btn.innerHTML = `<div class="w-5 h-5 border-2 border-white border-t-transparent rounded-full animate-spin"></div>`;
            err.classList.add('hidden');
            suc.classList.add('hidden');
            
            try {
                const res = await fetch('/api/auth/reset-password', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ token: currentResetToken, newPassword: pass })
                });
                const data = await res.json();
                
                if (res.ok && data.success) {
                    suc.textContent = data.message;
                    suc.classList.remove('hidden');
                    setTimeout(() => {
                        closeResetPasswordModal();
                        openAuthModal();
                    }, 2000);
                } else {
                    err.textContent = data.error || 'Erro a processar.';
                    err.classList.remove('hidden');
                }
            } catch(error) {
                err.textContent = 'Erro de rede.';
                err.classList.remove('hidden');
            }
            btn.innerHTML = `<span>Atualizar Password</span>`;
        }
    </script>
</body>
</html>



