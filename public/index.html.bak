                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0816692/img" class="w-full h-full object-cover"></div>
                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt1375666/img" class="w-full h-full object-cover"></div>
                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0133093/img" class="w-full h-full object-cover"></div>
                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0468569/img" class="w-full h-full object-cover"></div>
                <div class="w-32 h-48 flex-shrink-0 rounded-lg overflow-hidden "><img loading=" lazy\ decoding=\async\ src="https://images.metahub.space/poster/small/tt0111161/img" class="w-full h-full object-cover"></div>
            </div>

            <!-- Heavy cinematic overlays & Glassmorphism Blur -->
            <div class="absolute inset-0 bg-[#0f1115]/30 backdrop-blur-md z-10"></div>
            <div class="absolute inset-0 bg-gradient-to-b from-[#0f1115]/5 via-[#0f1115]/80 to-[#0f1115]/95 z-10"></div>
            <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_var(--tw-gradient-stops))] from-transparent via-[#0f1115]/30 to-[#0f1115]/90 z-10"></div>

            <!-- Animated Orbs for subtle color -->
            <div class="absolute top-1/4 left-1/4 w-72 h-72 bg-sky-500/15 rounded-full mix-blend-screen filter blur-3xl opacity-60 animate-blob z-20"></div>
            <div class="absolute top-1/3 right-1/4 w-72 h-72 bg-indigo-500/15 rounded-full mix-blend-screen filter blur-3xl opacity-60 animate-blob animation-delay-2000 z-20"></div>
            <div class="absolute -bottom-8 left-1/3 w-72 h-72 bg-purple-500/15 rounded-full mix-blend-screen filter blur-3xl opacity-60 animate-blob animation-delay-4000 z-20"></div>
        </div>

        <!-- Hero Section -->
        <div id="hero-header" class="text-center mb-8 mt-12 md:mt-24 w-full max-w-4xl animate-fade-in-up transition-all duration-500 relative z-10 flex flex-col items-center">
            
            <!-- Metallic/Brilliant gradient Title -->
            <h1 id="hero-title" class="font-display text-5xl md:text-7xl font-extrabold mb-5 tracking-tight leading-tight bg-clip-text text-transparent bg-gradient-to-br from-white via-slate-200 to-slate-500 drop-shadow-lg">
                Your Personal AI Film Curator
            </h1>
            <p id="hero-subtitle" class="text-lg md:text-xl text-slate-300 font-normal max-w-2xl mx-auto leading-relaxed drop-shadow">
                Search for a movie or series to watch instantly, or let us find your next favorite.
            </p>
        </div>

        <!-- Search Input Section -->
        <div id="search-container" class="bg-slate-900/40 backdrop-blur-lg border border-slate-700/50 rounded-2xl  p-3 w-full max-w-2xl mb-8 animate-fade-in-up transition-all duration-500" style="animation-delay: 100ms;">
            <form id="search-form" class="flex flex-col md:flex-row gap-3">
                <div class="relative flex-1">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
                    </div>
                    <input type="text" id="movie-input" autocomplete="new-password" data-lpignore="true" name="search_query_new" placeholder="e.g. Inception, The Matrix..." required class="w-full bg-slate-900/40 border border-slate-700/50 rounded-lg pl-11 pr-4 py-3.5 text-base focus:outline-none focus:ring-1 focus:ring-sky-500 focus:border-sky-500 transition-all placeholder-slate-500 text-white shadow-inner">
                </div>
                <div class="flex gap-2">
                    <button type="button" id="toggle-settings-btn" class="bg-slate-800/60 hover:bg-slate-700 border border-slate-700/60 text-slate-300 hover:text-white rounded-lg p-3.5 transition-all flex items-center justify-center shadow-md">
                        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                    </button>
                    <button type="submit" class="bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg px-8 py-3.5 text-base transition-all shadow-lg flex items-center justify-center min-w-[140px] flex-grow md:flex-grow-0">
                        <span id="btn-text">Discover</span>
                        <div id="btn-loader" class="loader hidden"></div>
                    </button>
                </div>
            </form>

            <!-- Autocomplete Dropdown (Pushes content down) -->
            <div id="autocomplete-dropdown" class="mt-3 bg-slate-900/60 backdrop-blur-xl border border-slate-700/50 rounded-xl  overflow-hidden hidden max-h-80 overflow-y-auto w-full transition-all duration-300">
                <ul id="autocomplete-list" class="flex flex-col text-left"></ul>
            </div>

            <!-- Collapsible Settings Drawer -->
            <div id="settings-drawer" class="hidden mt-4 p-5 rounded-xl bg-slate-900/40 border border-slate-700/50  backdrop-blur-lg animate-fade-in text-left">
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    
                    <!-- Left Section: AI Search Filters -->
                    <div class="flex flex-col gap-4">
                        <div class="flex items-center gap-2 pb-2 border-b border-slate-800/80">
                            <svg class="w-4 h-4 theme-accent-text" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3c2.755 0 5.455.232 8.083.678.533.09.917.556.917 1.096v1.044a2.25 2.25 0 01-.659 1.591l-5.432 5.432a2.25 2.25 0 00-.659 1.591v2.927a2.25 2.25 0 01-1.244 2.013L9.75 21v-6.568a2.25 2.25 0 00-.659-1.591L3.659 7.409A2.25 2.25 0 013 5.818V4.774c0-.54.384-1.006.917-1.096A48.32 48.32 0 0112 3z"/></svg>
                            <h4 id="settings-title" class="text-xs font-bold text-white uppercase tracking-wider text-slate-300">Advanced Filters</h4>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label id="lbl-min-rating" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Min IMDB Rating</label>
                                <select id="filter-min-rating" class="bg-slate-900 border border-slate-700/60 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-sky-500 theme-accent-ring text-white">
                                    <option value="all" id="opt-rating-all">All Ratings</option>
                                    <option value=">7.0">> 7.0</option>
                                    <option value=">8.0">> 8.0</option>
                                    <option value=">8.5">> 8.5</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5">
                                <label id="lbl-year" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Released After</label>
                                <input type="number" id="filter-year" placeholder="e.g. 2019" class="bg-slate-900 border border-slate-700/60 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-sky-500 theme-accent-ring text-white">
                            </div>
                        </div>
                    </div>
                    
                    <!-- Right Section: Discovery Focus Preferences -->
                    <div class="flex flex-col gap-4">
                        <div class="flex items-center gap-2 pb-2 border-b border-slate-800/80">
                            <svg class="w-4 h-4 theme-accent-text" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.53 16.122l9.37-9.37m0 0l-9.37-9.37M18.9 6.752H3.75"/></svg>
                            <h4 id="settings-custom-title" class="text-xs font-bold text-white uppercase tracking-wider text-slate-300">Discovery Focus</h4>
                        </div>
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div class="flex flex-col gap-1.5">
                                <label id="lbl-content-type" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Content Focus</label>
                                <select id="filter-content-type" class="bg-slate-900 border border-slate-700/60 rounded-lg px-3 py-2 text-xs focus:outline-none focus:ring-1 focus:ring-sky-500 theme-accent-ring text-white">
                                    <option value="any" id="opt-content-any">Mixed Content</option>
                                    <option value="movie" id="opt-content-movie">Movies Only</option>
                                    <option value="series" id="opt-content-series">TV Series Only</option>
                                </select>
                            </div>
                            <div class="flex flex-col gap-1.5 justify-center h-full pt-1">
                                <div class="flex items-center gap-1.5">
                                    <span id="lbl-surprise-me" class="text-[10px] font-bold text-slate-400 uppercase tracking-wider">Surprise Me Mode</span>
                                    <div class="relative group flex items-center justify-center">
                                        <svg class="w-3.5 h-3.5 text-slate-500 hover:text-sky-400 transition-colors cursor-help" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.063.852l-.708 2.836a.75.75 0 001.063.852l.041-.021M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9-3.75h.008v.008H12V8.25z"/>
                                        </svg>
                                        <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-48 p-2 rounded bg-slate-900 border border-slate-700/80  text-[10px] text-slate-300 font-normal leading-relaxed pointer-events-none opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-50 text-center">
                                            <span id="tooltip-surprise-me">Mixes in 2-3 highly-rated, critically acclaimed hidden indie gems or cult classics related to your search that still boast outstanding reviews.</span>
                                            <div class="absolute top-full left-1/2 -translate-x-1/2 border-4 border-transparent border-t-slate-900"></div>
                                        </div>
                                    </div>
                                </div>
                                <div class="flex items-center gap-3 mt-1.5">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                        <input type="checkbox" id="filter-surprise-me" class="sr-only peer">
                                        <div class="w-9 h-5 bg-slate-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-slate-400 peer-checked:after:bg-white after:border-slate-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-sky-500"></div>
                                    </label>
                                    <span id="desc-surprise-me" class="text-[10px] text-slate-500 leading-none">Mix in obscure hidden gems</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
            
            <!-- Separator below settings (visible only when settings-drawer is open) -->
            <div id="settings-divider" class="hidden h-[1px] bg-gradient-to-r from-transparent via-slate-800/80 to-transparent my-4"></div>
            
            <!-- Trending Searches -->
            <div class="mt-5 flex flex-wrap justify-center gap-2 items-center text-sm text-slate-400">
                <span class="mr-2 text-[10px] font-bold uppercase tracking-widest text-slate-500">Trending:</span>
                <div id="trending-container" class="flex flex-wrap justify-center gap-2 items-center">
                    <!-- Dynamic trending items will be rendered here -->
                </div>
            </div>

        </div>

        <div id="error-message" class="hidden -mt-4 mb-6 mx-auto max-w-3xl p-3 bg-red-900/40 border border-red-800/60 rounded-xl text-red-200 text-sm text-center shadow-lg relative z-10 w-full"></div>

        <!-- Watchlist Preview Section (Hidden unless logged in) -->
        <div id="frontpage-watchlist-section" class="hidden w-full max-w-5xl mb-12 animate-fade-in-up transition-all duration-500 relative z-10">
            <div class="flex justify-between items-end mb-4 px-2">
                <div>
                    <h3 id="frontpage-greeting" class="font-display text-xl font-bold text-white tracking-wide">Welcome back!</h3>
                    <p class="text-xs text-slate-400 mt-1">Here is a quick look at your watchlist.</p>
                </div>
                <button onclick="document.getElementById('nav-watchlist-btn').click()" class="text-xs text-sky-400 hover:text-sky-300 transition-colors font-medium flex items-center gap-1">
                    View All <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
            <div id="frontpage-watchlist-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4 layout-compact">
                <!-- Watchlist items will be injected here -->
            </div>
        </div>

        <!-- Feature highlights -->
        <div id="features-section" class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-3 gap-6 animate-fade-in-up transition-all duration-500 relative z-10" style="animation-delay: 200ms;">
            <div class="text-center p-6 group bg-slate-900/30 backdrop-blur-lg border border-slate-700/40 rounded-3xl  transition-all hover:bg-slate-800/40">
                <div class="mx-auto flex justify-center mb-4 transition-transform duration-300 group-hover:-translate-y-1">
                    <div class="bg-sky-500/10 p-3 rounded-2xl border border-sky-500/20 group-hover:border-sky-500/40 group-hover:bg-sky-500/20 transition-all duration-300 shadow-[0_0_15px_rgba(56,189,248,0.15)]">
                        <svg class="w-7 h-7 text-sky-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"/></svg>
                    </div>
                </div>
                <h3 id="feat1-title" class="text-base font-semibold text-white mb-1.5">AI-Powered Discovery</h3>
                <p id="feat1-desc" class="text-slate-400 text-xs leading-relaxed">Describe the mood or plot you want, and let our AI curate the perfect cinematic experience for your movie night.</p>
            </div>
            <div class="text-center p-6 group bg-slate-900/30 backdrop-blur-lg border border-slate-700/40 rounded-3xl  transition-all hover:bg-slate-800/40">
                <div class="mx-auto flex justify-center mb-4 transition-transform duration-300 group-hover:-translate-y-1">
                    <div class="bg-indigo-500/10 p-3 rounded-2xl border border-indigo-500/20 group-hover:border-indigo-500/40 group-hover:bg-indigo-500/20 transition-all duration-300 shadow-[0_0_15px_rgba(99,102,241,0.15)]">
                        <svg class="w-7 h-7 text-indigo-400" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M4.5 5.653c0-1.426 1.529-2.33 2.779-1.643l11.54 6.348c1.295.712 1.295 2.573 0 3.285L7.28 19.991c-1.25.687-2.779-.217-2.779-1.643V5.653z" clip-rule="evenodd" /></svg>
                    </div>
                </div>
                <h3 id="feat2-title" class="text-base font-semibold text-white mb-1.5">Watch Instantly</h3>
                <p id="feat2-desc" class="text-slate-400 text-xs leading-relaxed">Stop endless scrolling. Watch your matches instantly right here on our site.</p>
            </div>
            <div class="text-center p-6 group bg-slate-900/30 backdrop-blur-lg border border-slate-700/40 rounded-3xl  transition-all hover:bg-slate-800/40">
                <div class="mx-auto flex justify-center mb-4 transition-transform duration-300 group-hover:-translate-y-1">
                    <div class="bg-purple-500/10 p-3 rounded-2xl border border-purple-500/20 group-hover:border-purple-500/40 group-hover:bg-purple-500/20 transition-all duration-300 shadow-[0_0_15px_rgba(168,85,247,0.15)]">
                        <svg class="w-7 h-7 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0111.186 0z" /></svg>
                    </div>
                </div>
                <h3 id="feat3-title" class="text-base font-semibold text-white mb-1.5">Build Your Collection</h3>
                <p id="feat3-desc" class="text-slate-400 text-xs leading-relaxed">Save your favorite discoveries to your personal watchlist and never lose track of what to watch next.</p>
            </div>
        </div>

        <!-- Watchlist Header Section -->
        <div id="watchlist-header-container" class="w-full max-w-6xl mb-6 hidden-section text-left">
            <h2 class="text-3xl font-extrabold text-white flex items-center gap-2.5">
                <svg class="w-7 h-7 text-sky-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z"/></svg>
                <span id="watchlist-header-title">My Watchlist</span>
            </h2>
        </div>

        <!-- Reference Movie Section -->
        <div id="reference-movie-container" class="w-full max-w-6xl mb-4 opacity-0 transition-opacity duration-700 hidden-section flex flex-col items-center"></div>

        <!-- Results Section -->
        <div id="results-container" class="w-full max-w-6xl flex flex-wrap justify-center gap-5 opacity-0 transition-opacity duration-700 hidden-section"></div>
        
        <!-- Load More Section -->
        <div id="load-more-container" class="w-full max-w-6xl flex justify-center mt-6 mb-12 hidden opacity-0 transition-opacity duration-500 hidden-section">
            <button id="btn-load-more" class="px-6 py-2.5 rounded-full bg-slate-800 hover:bg-slate-700 text-slate-300 border border-slate-600 transition-all font-semibold text-sm flex items-center gap-2 shadow-lg hover:shadow-sky-500/20">
                <span id="load-more-text">Load 5 more suggestions</span>
                <svg id="load-more-spinner" class="animate-spin -ml-1 mr-2 h-4 w-4 text-sky-500 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>
            </button>
        </div>
    </div>

    <!-- Movie Details Modal -->
    <div id="details-modal" class="fixed inset-0 z-[60] flex items-center justify-center modal-overlay hidden p-0 md:p-6">
        <div class="absolute inset-0 bg-slate-950/95" onclick="closeDetailsModal()"></div>
        <div class="relative w-full max-w-5xl bg-slate-900 border-none md:border md:border-slate-700/50 rounded-none md:rounded-2xl overflow-hidden flex flex-col h-full md:h-auto md:max-h-[95vh] transform transition-all">
            
            <button onclick="closeDetailsModal()" class="absolute top-4 right-4 z-20 bg-black/60 p-3 md:p-2 rounded-full text-slate-300 hover:text-white hover:bg-black/90 transition-all md:backdrop-blur-sm shadow-lg">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>

            <!-- Loading State -->
            <div id="details-loading" class="flex flex-col items-center justify-center py-32 h-full z-10 bg-slate-900">
                <div class="loader mb-4 border-t-sky-500 w-12 h-12"></div>
                <p class="text-slate-400">Loading details...</p>
            </div>

            <!-- Content State -->
            <div id="details-content" class="hidden overflow-y-auto flex-grow flex flex-col relative w-full pb-8">
                <!-- Header with Background -->
                <div class="relative w-full h-64 md:h-96 flex-shrink-0">
                    <div id="details-bg" class="absolute inset-0 bg-cover bg-center transition-all duration-700" style="background-image: url('');"></div>
                    <!-- Gradient Overlays -->
                    <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/60 to-transparent"></div>
                    <div class="absolute inset-0 bg-gradient-to-r from-slate-900 via-slate-900/80 to-transparent w-2/3"></div>
                    
                    <!-- Header Info Overlay -->
                    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-8 flex flex-col md:flex-row gap-6 items-end">
                        <img loading=\lazy\ decoding=\async\ id="details-poster" src="" class="w-32 md:w-48 rounded-xl  border border-slate-700/50 hidden md:block" onerror="this.style.display='none'">
                        <div class="flex flex-col gap-2 w-full">
                            <h2 id="details-title" class="text-3xl md:text-5xl font-bold text-white mb-1 shadow-black drop-shadow-md">Title</h2>
                            <div class="flex flex-wrap items-center gap-3 text-sm md:text-base font-medium">
                                <span id="details-year" class="text-sky-400">2024</span>
                                <span class="text-slate-500">&bull;</span>
                                <span id="details-rating" class="flex items-center gap-1 text-amber-400"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg> <span id="details-rating-val">8.0</span></span>
                                <span class="text-slate-500">&bull;</span>
                                <span id="details-duration" class="text-slate-300">120 min</span>
                                <span class="text-slate-500">&bull;</span>
                                <span id="details-type" class="px-2 py-0.5 rounded text-xs font-bold bg-slate-800 text-slate-300 uppercase tracking-wider">Movie</span>
                            </div>
                            <div id="details-genres" class="flex flex-wrap gap-2 mt-2">
                                <!-- Genre pills injected here -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Body Content -->
                <div class="px-6 md:px-8 py-6 flex flex-col md:flex-row gap-8">
                    <!-- Left Column (Plot & Buttons) -->
                    <div class="flex-grow md:w-2/3 flex flex-col gap-6">
                        <div>
                            <h3 class="text-lg font-semibold text-white mb-2">Synopsis</h3>
                            <p id="details-plot" class="text-slate-300 leading-relaxed">Plot description goes here...</p>
                        </div>
                        
                        <!-- Action Buttons -->
                        <div class="flex flex-wrap gap-3 mt-2" id="details-buttons">
                            <!-- Buttons injected here dynamically to include Trailer -->
                        </div>
                    </div>
                    
                    <!-- Right Column (Cast & Crew) -->
                    <div class="md:w-1/3 flex flex-col gap-6 border-t md:border-t-0 md:border-l border-slate-700/50 pt-6 md:pt-0 md:pl-8">
                        <div>
                            <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Director</h3>
                            <p id="details-director" class="text-white">N/A</p>
                        </div>
                        <div>
                            <h3 class="text-sm font-semibold text-slate-400 uppercase tracking-wider mb-2">Cast</h3>
                            <div id="details-cast" class="flex flex-col gap-1 text-slate-300">
                                <!-- Cast members -->
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Cookie Banner -->
    <div id="cookie-banner" class="fixed bottom-0 left-0 right-0 bg-slate-900/95 backdrop-blur-md border-t border-slate-700/50 p-4 md:p-6 z-50 transform translate-y-full transition-transform duration-500 flex flex-col md:flex-row items-center justify-between gap-4 shadow-[0_-10px_40px_rgba(0,0,0,0.5)]">
        <p id="cookie-text" class="text-sm text-slate-300 text-center md:text-left flex-1"></p>
        <button id="cookie-btn" onclick="acceptCookies()" class="bg-sky-600 hover:bg-sky-500 text-white text-sm font-bold px-6 py-2.5 rounded-lg transition-colors whitespace-nowrap shadow-lg shadow-sky-900/20"></button>
    </div>

    <!-- Scripts -->
    <!-- Beautiful Footer -->
    <footer class="w-full border-t border-slate-800 bg-slate-900/60 mt-auto relative z-10 py-10 px-6">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row justify-between gap-10 md:gap-4">
            <!-- Brand -->
            <div class="flex flex-col gap-3 max-w-xs">
                <h3 class="text-xl font-black text-white tracking-tight flex items-center gap-2">
                    <span class="bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-blue-500">CineMatch</span> AI
                </h3>
                <p id="footer-desc" class="text-slate-400 text-xs leading-relaxed">O teu assistente pessoal de cinema impulsionado por Inteligência Artificial. Descobre o teu próximo filme favorito.</p>
                <div class="text-slate-500 text-[10px] mt-2">© 2026 CineMatch AI.</div>
            </div>
            
            <!-- Legal -->
            <div class="flex flex-col gap-3">
                <h4 id="footer-legal-title" class="text-white text-sm font-semibold uppercase tracking-wider mb-1">Legal</h4>
                <button onclick="openLegalModal('terms-modal')" class="text-left text-slate-400 hover:text-sky-400 text-xs transition-colors" id="footer-terms">Termos de Serviço</button>
                <button onclick="openLegalModal('privacy-modal')" class="text-left text-slate-400 hover:text-sky-400 text-xs transition-colors" id="footer-privacy">Política de Privacidade</button>
                <button onclick="openLegalModal('dmca-modal')" class="text-left text-slate-400 hover:text-sky-400 text-xs transition-colors" id="footer-dmca">Aviso de Direitos (DMCA)</button>
            </div>

            <!-- Platform -->
            <div class="flex flex-col gap-3">
                <h4 id="footer-platform-title" class="text-white text-sm font-semibold uppercase tracking-wider mb-1">Plataforma</h4>
                <button onclick="openLegalModal('faq-modal')" class="text-left text-slate-400 hover:text-sky-400 text-xs transition-colors" id="footer-faq">Perguntas Frequentes (FAQ)</button>
                <button onclick="openContactModal()" class="text-left text-slate-400 hover:text-sky-400 text-xs transition-colors" id="footer-contact">Contactar Suporte</button>
                <button onclick="openSupportModal()" class="text-left text-amber-400/80 hover:text-amber-400 text-xs transition-colors" id="footer-donate">Apoiar Projeto 💖</button>
            </div>
        </div>
    </footer>

    <!-- Generic Modal Template for Legal/FAQ -->
    <div id="terms-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4 opacity-0 transition-opacity duration-300">
        <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" onclick="closeLegalModal('terms-modal')"></div>
        <div class="relative w-full max-w-2xl max-h-[85vh] flex flex-col bg-slate-900 border border-slate-700/50 rounded-2xl  transform scale-95 transition-all duration-300">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center shrink-0">
                <h3 class="text-xl font-bold text-white" id="terms-title">Termos de Serviço</h3>
                <button onclick="closeLegalModal('terms-modal')" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="p-6 overflow-y-auto text-sm text-slate-300 leading-relaxed space-y-4 custom-scrollbar" id="terms-content">
            </div>
        </div>
    </div>
    
    <div id="privacy-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4 opacity-0 transition-opacity duration-300">
        <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" onclick="closeLegalModal('privacy-modal')"></div>
        <div class="relative w-full max-w-2xl max-h-[85vh] flex flex-col bg-slate-900 border border-slate-700/50 rounded-2xl  transform scale-95 transition-all duration-300">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center shrink-0">
                <h3 class="text-xl font-bold text-white" id="privacy-title">Política de Privacidade</h3>
                <button onclick="closeLegalModal('privacy-modal')" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
