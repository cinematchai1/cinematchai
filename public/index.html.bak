<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#0f1115">
    <link rel="icon" type="image/png" href="/favicon.png">
    <link rel="apple-touch-icon" href="/favicon.png">
    <link rel="manifest" href="/manifest.json">
    <title>CineMatch AI | Premium Movie Recommendations</title>
    
    <!-- Network Handshakes & Preloads -->
    <link rel="preconnect" href="https://images.metahub.space" crossorigin>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;700;800&display=swap">
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            fontFamily: {
              display: ['Outfit', 'sans-serif'],
              sans: ['Inter', 'sans-serif'],
            }
          }
        }
      }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --accent-rgb: 56, 189, 248; /* default sky-400 */
            --accent-hex: #38bdf8;
            --accent-hover: #0ea5e9;
        }

        body[data-theme="sky"] {
            --accent-rgb: 56, 189, 248;
            --accent-hex: #38bdf8;
            --accent-hover: #0ea5e9;
        }
        body[data-theme="purple"] {
            --accent-rgb: 168, 85, 247;
            --accent-hex: #a855f7;
            --accent-hover: #9333ea;
        }
        body[data-theme="emerald"] {
            --accent-rgb: 16, 185, 129;
            --accent-hex: #10b981;
            --accent-hover: #059669;
        }
        body[data-theme="rose"] {
            --accent-rgb: 244, 63, 94;
            --accent-hex: #f43f5e;
            --accent-hover: #e11d48;
        }
        body[data-theme="amber"] {
            --accent-rgb: 245, 158, 11;
            --accent-hex: #f59e0b;
            --accent-hover: #d97706;
        }

        /* Dynamic theme accent overrides for utility classes */
        .text-sky-500, .theme-accent-text { color: var(--accent-hex) !important; }
        .text-sky-400 { color: var(--accent-hex) !important; }
        .bg-sky-600, .theme-accent-bg { background-color: var(--accent-hex) !important; }
        .hover\:bg-sky-500:hover, .theme-accent-bg-hover:hover { background-color: var(--accent-hover) !important; }
        .bg-sky-600\/10 { background-color: rgba(var(--accent-rgb), 0.1) !important; }
        .hover\:bg-sky-600\/20:hover { background-color: rgba(var(--accent-rgb), 0.2) !important; }
        .border-sky-500\/20 { border-color: rgba(var(--accent-rgb), 0.2) !important; }
        .hover\:border-sky-500\/40:hover { border-color: rgba(var(--accent-rgb), 0.4) !important; }
        .focus\:ring-sky-500:focus { --tw-ring-color: var(--accent-hex) !important; }
        .focus\:border-sky-500:focus { border-color: var(--accent-hex) !important; }
        .border-t-sky-500 { border-top-color: var(--accent-hex) !important; }
        .bg-sky-500\/20 { background-color: rgba(var(--accent-rgb), 0.15) !important; }
        .border-sky-500\/30 { border-color: rgba(var(--accent-rgb), 0.3) !important; }
        .bg-sky-400\/10 { background-color: rgba(var(--accent-rgb), 0.12) !important; }
        .border-sky-400\/20 { border-color: rgba(var(--accent-rgb), 0.25) !important; }
        .from-sky-600 {
            --tw-gradient-from: var(--accent-hex) !important;
            --tw-gradient-to: rgb(79 70 229 / 0) !important;
            --tw-gradient-stops: var(--tw-gradient-from), var(--tw-gradient-to) !important;
        }
        .hover\:from-sky-500:hover {
            --tw-gradient-from: var(--accent-hover) !important;
        }
        .accent-sky-500 {
            accent-color: var(--accent-hex) !important;
        }
        input[type="range"] {
            accent-color: var(--accent-hex) !important;
        }
        
        /* Interactive features dynamic indicator and card highlights */
        .shadow-\[0_0_15px_rgba\(56\,189\,248\,0\.5\)\] {
            box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.5) !important;
        }
        .shadow-\[0_0_15px_rgba\(56\,189\,248\,0\.15\)\] {
            box-shadow: 0 0 15px rgba(var(--accent-rgb), 0.15) !important;
        }
        .shadow-\[0_0_30px_rgba\(56\,189\,248\,0\.2\)\] {
            box-shadow: 0 0 30px rgba(var(--accent-rgb), 0.2) !important;
        }

        /* Compact Density layout specifications */
        .layout-compact .movie-card h3 { font-size: 0.875rem !important; line-height: 1.2 !important; }
        .layout-compact .movie-card p { display: none !important; }
        .layout-compact .movie-card .p-4 { padding: 0.75rem !important; }
        .layout-compact .movie-card .mt-3 { margin-top: 0.5rem !important; }
        .layout-compact .movie-card .gap-2 { gap: 0.25rem !important; }
        .layout-compact .movie-card .mb-2\.5 { margin-bottom: 0.35rem !important; }
        .layout-compact .movie-card .py-2 { padding-top: 0.375rem !important; padding-bottom: 0.375rem !important; }
        .layout-compact .movie-card .py-1\.5 { padding-top: 0.25rem !important; padding-bottom: 0.25rem !important; }
        .layout-compact .movie-card .text-xs { font-size: 0.75rem !important; }
        .layout-compact .movie-card .text-\[10px\] { font-size: 9px !important; }

        body {
            font-family: 'Inter', sans-serif;
            background-color: #0f1115;
            background-image: radial-gradient(circle at 15% 50%, rgba(20, 30, 48, 0.4), transparent 50%), 
                              radial-gradient(circle at 85% 30%, rgba(36, 59, 85, 0.4), transparent 50%);
            color: #e2e8f0;
            min-height: 100vh;
            overflow-x: hidden;
            overscroll-behavior: none;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }

        .glass-panel {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 1.25rem;
            box-shadow: 0 4px 24px -1px rgba(0, 0, 0, 0.2);
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        }
        
        @media (min-width: 768px) {
            .glass-panel {
                backdrop-filter: blur(16px);
                -webkit-backdrop-filter: blur(16px);
            }
        }

        .movie-card {
            transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
            transform: translateZ(0);
            -webkit-backface-visibility: hidden;
            content-visibility: auto;
            contain-intrinsic-size: 200px 300px;
        }

        .movie-card:hover {
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 0 15px 1px rgba(56, 189, 248, 0.15);
            border-color: rgba(56, 189, 248, 0.3);
        }
        
        @media (pointer: fine) {
            .movie-card {
                perspective: 1000px;
                transform-style: preserve-3d;
                position: relative;
            }
            .movie-card::after {
                content: '';
                position: absolute;
                inset: 0;
                z-index: 5;
                background: radial-gradient(
                    600px circle at var(--mouse-x, 0) var(--mouse-y, 0),
                    rgba(255, 255, 255, 0.08),
                    transparent 40%
                );
                opacity: 0;
                transition: opacity 0.3s ease;
                pointer-events: none;
                border-radius: inherit;
            }
            .movie-card:hover::after {
                opacity: 1;
            }
        }

        .loader {
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-top: 3px solid #ffffff;
            border-radius: 50%;
            width: 24px;
            height: 24px;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }

        @keyframes blob {
            0% { transform: translate(0px, 0px) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
            100% { transform: translate(0px, 0px) scale(1); }
        }

        .animate-blob {
            animation: blob 7s infinite;
        }
        .animation-delay-2000 {
            animation-delay: 2s;
        }
        .animation-delay-4000 {
            animation-delay: 4s;
        }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #0f1115; }
        ::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #475569; }

        .hidden-section { display: none !important; }

        /* Smooth Section Transitions */
        .page-transition {
            transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1), transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .page-enter {
            opacity: 0;
            transform: translateY(12px);
        }
        .page-enter-active {
            opacity: 1;
            transform: translateY(0);
        }
        .page-exit {
            opacity: 1;
            transform: translateY(0);
        }
        .page-exit-active {
            opacity: 0;
            transform: translateY(-12px);
        }

        /* Micro-interactions for buttons */
        .btn-interactive {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-interactive:hover {
            transform: translateY(-1px);
        }
        .btn-interactive:active {
            transform: scale(0.96) translateY(0);
        }

        .watchlist-btn {
            transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .watchlist-btn:hover {
            transform: scale(1.1);
        }
        .watchlist-btn:active {
            transform: scale(0.92);
        }

        .modal-overlay {
            background: rgba(0, 0, 0, 0.85);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        
        @media (min-width: 768px) {
            .modal-overlay {
                backdrop-filter: blur(8px);
                background: rgba(0, 0, 0, 0.75);
            }
        }
        .modal-overlay.active {
            opacity: 1;
            pointer-events: auto;
        }
        .modal-content {
            transform: scale(0.95) translateY(10px);
            transition: transform 0.3s ease;
        }
        .modal-overlay.active .modal-content {
            transform: scale(1) translateY(0);
        }
        @keyframes loading-bar {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(200%); }
        }
        .animate-loading-bar {
            animation: loading-bar 1.5s infinite linear;
            width: 50%;
        }

        @keyframes scroll-posters {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }
        .animate-scroll-posters {
            animation: scroll-posters 30s linear infinite;
            width: max-content;
            will-change: transform;
        }
        .mask-edges {
            mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
            -webkit-mask-image: linear-gradient(to right, transparent, black 15%, black 85%, transparent);
        }
    </style>
</head>
<body class="antialiased overflow-x-hidden relative">
    
    <!-- Top Nav -->
    <div id="nav-bar" class="w-full max-w-7xl mx-auto flex justify-between items-center px-4 py-4 sm:p-6 relative z-50">
        <div class="flex items-center gap-4">
            <button onclick="goHome()" class="text-xl sm:text-2xl font-bold tracking-tight text-white flex items-center gap-1.5 sm:gap-2 hover:opacity-80 transition-opacity focus:outline-none">
                <svg class="w-6 h-6 text-sky-500" fill="currentColor" viewBox="0 0 24 24"><path d="M19.82 2H4.18C2.97 2 2 2.97 2 4.18v15.64C2 21.03 2.97 22 4.18 22h15.64c1.21 0 2.18-.97 2.18-2.18V4.18C22 2.97 21.03 2 19.82 2zM10 16.5v-9l6 4.5-6 4.5z"/></svg>
                <span class="bg-clip-text text-transparent bg-gradient-to-r from-sky-400 to-indigo-500">CineMatch</span> AI
            </button>
            <button onclick="openSupportModal()" class="text-xs font-bold px-2.5 py-1.5 sm:px-4 sm:py-2 rounded-lg bg-pink-600/20 hover:bg-pink-600/30 text-pink-400 hover:text-pink-300 border border-pink-500/20 hover:border-pink-500/40 transition-all duration-300 uppercase tracking-wider flex items-center gap-1 sm:gap-1.5 shadow-sm">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                <span id="nav-support-text" class="hidden sm:inline">Support Us</span>
            </button>
        </div>
        <div class="flex items-center gap-2 sm:gap-4">
            <div class="relative group">
                <button id="lang-toggle-btn" class="flex items-center gap-1 sm:gap-1.5 text-xs font-semibold px-2 py-1.5 sm:px-3 sm:py-1.5 rounded bg-slate-800 hover:bg-slate-700 text-slate-300 border border-slate-700 transition-colors uppercase">
                    <img loading=\lazy\ decoding=\async\ id="current-lang-flag" src="https://flagcdn.com/w20/gb.png" class="w-4 rounded-[1px] opacity-90" alt="Flag">
                    <span id="current-lang-display">ENG</span>
                    <svg class="w-3 h-3 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </button>
                <div class="absolute right-0 top-full pt-3 -mt-2 w-28 z-50 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-opacity duration-200">
                    <div class="bg-slate-800 border border-slate-700 rounded-md shadow-xl overflow-hidden">
                        <button class="lang-option w-full flex items-center gap-2.5 px-3 py-2 text-xs font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors" data-lang="en">
                            <img loading=" lazy\ decoding=\async\ src="https://flagcdn.com/w20/gb.png" class="w-4 rounded-[1px] pointer-events-none" alt="UK Flag"> ENG
                        </button>
                        <button class="lang-option w-full flex items-center gap-2.5 px-3 py-2 text-xs font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition-colors" data-lang="pt">
                            <img loading=" lazy\ decoding=\async\ src="https://flagcdn.com/w20/pt.png" class="w-4 rounded-[1px] pointer-events-none" alt="PT Flag"> PT
                        </button>
                    </div>
                </div>
            </div>

            <div id="nav-actions" class="flex items-center gap-2 sm:gap-3"></div>
        </div>
    </div>

    <!-- Main Section -->
    <div class="container mx-auto px-4 pt-4 pb-12 flex flex-col items-center justify-center min-h-[80vh] relative">
        
        <!-- Animated Cinematic Background -->
        <div id="dynamic-bg" class="fixed inset-0 w-full h-full overflow-hidden pointer-events-none z-0">
            <!-- Infinity Poster Wall Background (High-Res) -->
