        </div>
    </div>

    <div id="faq-modal" class="fixed inset-0 z-50 flex items-center justify-center hidden p-4 opacity-0 transition-opacity duration-300">
        <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" onclick="closeLegalModal('faq-modal')"></div>
        <div class="relative w-full max-w-2xl max-h-[85vh] flex flex-col bg-slate-900 border border-slate-700/50 rounded-2xl  transform scale-95 transition-all duration-300">
            <div class="p-6 border-b border-slate-800 flex justify-between items-center shrink-0">
                <h3 class="text-xl font-bold text-white" id="faq-title">Perguntas Frequentes (FAQ)</h3>
                <button onclick="closeLegalModal('faq-modal')" class="text-slate-400 hover:text-white transition-colors">
