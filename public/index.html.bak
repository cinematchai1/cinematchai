    <!-- Contact Modal -->
    <div id="contact-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-overlay hidden p-4">
        <div class="absolute inset-0 bg-slate-950/80 backdrop-blur-sm" onclick="closeContactModal()"></div>
        <div class="relative w-full max-w-sm bg-slate-900 border border-slate-700/50 rounded-2xl  p-6 md:p-8 transform transition-all">
            <button onclick="closeContactModal()" class="absolute top-4 right-4 text-slate-400 hover:text-white transition-colors">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div class="text-center mb-6">
                <h3 class="text-xl font-bold text-white mb-2" id="contact-title">Contact Support</h3>
                <p class="text-slate-400 text-xs" id="contact-desc">Reach out to us via email for any bugs, suggestions or questions.</p>
            </div>
            
            <div class="bg-slate-950 p-3 rounded-xl border border-slate-800 mb-6 flex items-center justify-between group">
                <span class="text-slate-300 font-mono text-sm ml-1">info@cinematchai.com</span>
                <button onclick="navigator.clipboard.writeText('info@cinematchai.com'); showToast(translations[currentLang].contactCopiedToast);" class="text-sky-500 hover:text-sky-400 bg-sky-500/10 hover:bg-sky-500/20 px-3 py-1.5 rounded-lg text-xs font-medium transition-colors" id="contact-copy-btn">
                    Copy
                </button>
            </div>

            <div class="grid grid-cols-2 gap-3">
                <a href="https://mail.google.com/mail/?view=cm&fs=1&to=info@cinematchai.com&su=CineMatch%20Support" target="_blank" class="flex flex-col items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-white rounded-xl p-3 transition-colors border border-slate-700">
                    <svg class="w-6 h-6 text-red-500" viewBox="0 0 24 24" fill="currentColor"><path d="M24 5.457v13.909c0 .904-.732 1.636-1.636 1.636h-3.819V11.73L12 16.64l-6.545-4.91v9.273H1.636A1.636 1.636 0 0 1 0 19.366V5.457c0-2.023 2.309-3.178 3.927-1.964L5.455 4.64 12 9.548l6.545-4.91 1.528-1.145C21.69 2.28 24 3.434 24 5.457z"/></svg>
                    <span class="text-xs font-medium">Gmail Web</span>
                </a>
                <a href="mailto:info@cinematchai.com?subject=CineMatch%20Support" class="flex flex-col items-center justify-center gap-2 bg-slate-800 hover:bg-slate-700 text-white rounded-xl p-3 transition-colors border border-slate-700">
                    <svg class="w-6 h-6 text-sky-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                    <span class="text-xs font-medium" id="contact-app-btn">Email App</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Forgot Password Modal -->
    <div id="forgot-password-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div class="bg-slate-800 border border-slate-700 p-6 rounded-2xl w-full max-w-sm  transform scale-95 transition-transform duration-300 mx-4">
            <div class="flex justify-between items-center mb-6">
                <h2 id="forgot-password-title" class="text-xl font-bold text-white">Recuperar Password</h2>
                <button onclick="closeForgotPasswordModal()" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
            </div>
            
            <form id="forgot-password-form" onsubmit="handleForgotPassword(event)" class="flex flex-col gap-3">
                <p id="forgot-password-desc" class="text-xs text-slate-300 mb-2">Insere o teu email abaixo e enviar-te-emos um link para redefinir a tua password.</p>
                <input type="text" id="forgot-email" placeholder="Email" required class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                
                <div id="forgot-error" class="text-red-400 text-xs hidden text-center"></div>
                <div id="forgot-success" class="text-green-400 text-xs hidden text-center"></div>
                
                <button type="submit" id="forgot-btn" class="mt-2 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-all shadow-md w-full flex justify-center items-center">
                    <span id="forgot-password-btn-text">Enviar Link</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Reset Password Modal -->
    <div id="reset-password-modal" class="fixed inset-0 bg-black/60 backdrop-blur-sm z-50 flex items-center justify-center hidden opacity-0 transition-opacity duration-300">
        <div class="bg-slate-800 border border-slate-700 p-6 rounded-2xl w-full max-w-sm  transform scale-95 transition-transform duration-300 mx-4">
            <h2 class="text-xl font-bold text-white mb-6">Nova Password</h2>
            
            <form id="reset-password-form" onsubmit="handleResetPassword(event)" class="flex flex-col gap-3">
                <input type="password" id="reset-new-pass" placeholder="Nova Password" required class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                
                <div id="reset-error" class="text-red-400 text-xs hidden text-center"></div>
                <div id="reset-success" class="text-green-400 text-xs hidden text-center"></div>
                
                <button type="submit" id="reset-btn" class="mt-2 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-all shadow-md w-full flex justify-center items-center">
                    <span>Atualizar Password</span>
                </button>
            </form>
        </div>
    </div>

    <!-- Profile Modal -->
    <div id="profile-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-overlay hidden p-0 md:p-4">
        <div class="absolute inset-0 bg-slate-950/95" onclick="closeProfileModal()"></div>
        <div class="relative w-full h-full md:h-auto md:max-h-[95vh] max-w-3xl bg-slate-900 border-none md:border md:border-slate-700/50 rounded-none md:rounded-2xl p-6 md:p-8 transform transition-all overflow-y-auto">
            <button onclick="closeProfileModal()" class="absolute top-4 right-4 p-2 text-slate-400 hover:text-white transition-colors bg-black/40 md:bg-transparent rounded-full md:rounded-none">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
            <div class="text-center mb-8">
                <h3 id="modal-profile-title" class="text-2xl md:text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-sky-400 to-indigo-500 tracking-tight">AI Recommendation Engine</h3>
                <p id="modal-profile-desc" class="text-slate-400 text-sm mt-2 font-medium">Tune your algorithm for personalized results</p>
            </div>
            
            <form id="profile-form" class="flex flex-col gap-6">
                
                <!-- Appearance Section -->
                <div class="flex flex-col gap-5 mb-2">
                    <div class="pb-3 border-b border-slate-800">
                        <h4 class="text-lg font-semibold text-slate-200" id="lbl-prof-appearance">Appearance</h4>
                    </div>
                    <div class="flex flex-col sm:flex-row gap-6 items-start sm:items-center">
                        <div class="flex flex-col items-center gap-3">
                            <div class="relative w-24 h-24 rounded-full border-2 border-slate-700 bg-slate-800 overflow-hidden flex items-center justify-center shadow-lg group">
                                <img loading=\lazy\ decoding=\async\ id="prof-avatar-preview" src="" class="w-full h-full object-cover hidden">
                                <div id="prof-avatar-initials" class="w-full h-full flex items-center justify-center text-3xl font-bold text-white bg-gradient-to-br from-slate-700 to-slate-900 hidden"></div>
                                <div class="absolute inset-0 bg-black/50 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity cursor-pointer" onclick="document.getElementById('prof-avatar-upload').click()">
                                    <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
                                </div>
                            </div>
                            <input type="file" id="prof-avatar-upload" accept="image/*" class="hidden" onchange="handleAvatarUpload(this.files)">
                        </div>
                        <div class="flex-1 flex flex-col gap-4 w-full">
                            <div>
                                <label id="lbl-prof-display-name" class="block text-sm font-medium text-slate-300 mb-1.5">Display Name</label>
                                <input type="text" id="prof-display-name" placeholder="Your display name" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                            </div>
                            <div>
                                <label id="lbl-prof-preset-avatars" class="block text-sm font-medium text-slate-400 mb-1.5">Or choose an avatar:</label>
                                <div class="flex items-center gap-3 overflow-x-auto pb-2 custom-scrollbar">
                                    <img loading=" lazy\ decoding=\async\ src="/assets/avatars/avatar1.svg" class="w-10 h-10 rounded-full cursor-pointer border border-transparent hover:border-sky-500 transition-colors" onclick="selectPresetAvatar('/assets/avatars/avatar1.svg')">
                                    <img loading=" lazy\ decoding=\async\ src="/assets/avatars/avatar2.svg" class="w-10 h-10 rounded-full cursor-pointer border border-transparent hover:border-sky-500 transition-colors" onclick="selectPresetAvatar('/assets/avatars/avatar2.svg')">
                                    <img loading=" lazy\ decoding=\async\ src="/assets/avatars/avatar3.svg" class="w-10 h-10 rounded-full cursor-pointer border border-transparent hover:border-sky-500 transition-colors" onclick="selectPresetAvatar('/assets/avatars/avatar3.svg')">
                                    <img loading=" lazy\ decoding=\async\ src="/assets/avatars/avatar4.svg" class="w-10 h-10 rounded-full cursor-pointer border border-transparent hover:border-sky-500 transition-colors" onclick="selectPresetAvatar('/assets/avatars/avatar4.svg')">
                                    <img loading=" lazy\ decoding=\async\ src="/assets/avatars/avatar5.svg" class="w-10 h-10 rounded-full cursor-pointer border border-transparent hover:border-sky-500 transition-colors" onclick="selectPresetAvatar('/assets/avatars/avatar5.svg')">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- Left Column: Core Settings -->
                    <div class="flex flex-col gap-5">
                        <div class="pb-3 border-b border-slate-800">
                            <h4 class="text-lg font-semibold text-slate-200">System DNA</h4>
                        </div>
                        <div>
                            <label id="lbl-accent-theme" class="block text-sm font-medium text-slate-300 mb-1.5">Visual: Accent Theme</label>
                            <select id="setting-accent-theme" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                                <option value="sky" id="opt-theme-sky">Sky Cyan</option>
                                <option value="purple" id="opt-theme-purple">Neon Purple</option>
                                <option value="emerald" id="opt-theme-emerald">Emerald Green</option>
                                <option value="rose" id="opt-theme-rose">Rose Pink</option>
                                <option value="amber" id="opt-theme-amber">Sunset Amber</option>
                            </select>
                        </div>
                        <div>
                            <label id="lbl-prof-lang" class="block text-sm font-medium text-slate-300 mb-1.5">Preferred Language</label>
                            <select id="prof-lang" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                                <option value="en">English</option>
                                <option value="pt">Português</option>
                            </select>
                        </div>
                        <div>
                            <label id="lbl-prof-type" class="block text-sm font-medium text-slate-300 mb-1.5">Preferred Media Type</label>
                            <select id="prof-type" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                                <option value="any">Any (Movies & Series)</option>
                                <option value="movie">Movies Only</option>
                                <option value="series">Series Only</option>
                            </select>
                        </div>
                        <div>
                            <label id="lbl-prof-rating" class="block text-sm font-medium text-slate-300 mb-1.5">Minimum IMDB Rating</label>
                            <select id="prof-rating" class="w-full bg-slate-800/50 border border-slate-700 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-sky-500 focus:ring-1 focus:ring-sky-500 transition-all">
                                <option value="">No Minimum</option>
                                <option value="7.0">> 7.0</option>
                                <option value="8.0">> 8.0</option>
                                <option value="8.5">> 8.5</option>
                            </select>
                        </div>
                    </div>
                    
                    <!-- Right Column: Genre Tuning -->
                    <div class="flex flex-col gap-5">
                        <div class="pb-3 border-b border-slate-800 flex justify-between items-end">
                            <h4 id="lbl-prof-fav" class="text-lg font-semibold text-slate-200">Genre Preferences</h4>
                            <span id="lbl-prof-genres-help" class="text-xs text-slate-500 font-medium">Click to toggle</span>
                        </div>
                        
                        <div class="flex flex-wrap gap-2" id="genre-grid">
                            <!-- Populated by JS -->
                        </div>
                        
                        <div class="mt-auto pt-4 flex gap-4 text-xs text-slate-400 font-medium border-t border-slate-800/50">
                            <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-slate-800 border border-slate-700"></div> Neutral</div>
                            <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-emerald-500/20 border border-emerald-500"></div> Favorite</div>
                            <div class="flex items-center gap-1.5"><div class="w-3 h-3 rounded-full bg-red-500/20 border border-red-500"></div> Excluded</div>
                        </div>
                    </div>
                </div>
                
                <button type="submit" class="mt-4 w-full bg-gradient-to-r from-sky-600 to-indigo-600 hover:from-sky-500 hover:to-indigo-500 text-white font-bold py-4 px-4 rounded-xl transition-all shadow-lg shadow-indigo-900/30 flex justify-center items-center gap-2 text-lg">
                    <span id="prof-btn-text">Apply Configuration</span>
                    <div id="prof-loader" class="loader hidden w-5 h-5 border-2"></div>
                </button>
            </form>
        </div>
    </div>

    <!-- Support Modal -->
    <div id="support-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-overlay p-0 md:p-4">
        <div class="glass-panel p-6 md:p-8 w-full h-full md:h-auto max-w-md modal-content relative bg-[#0f1115]/95 border-none md:border md:border-pink-700/50 rounded-none md:rounded-2xl overflow-y-auto">
            <button onclick="closeSupportModal()" class="absolute top-4 right-4 p-3 md:p-2 bg-black/40 md:bg-transparent rounded-full md:rounded-none text-slate-500 hover:text-white text-2xl leading-none w-10 h-10 flex items-center justify-center">&times;</button>
            <div class="text-center mb-6">
                <h2 class="text-2xl font-bold text-white mb-2" id="support-title">Support CineMatch</h2>
                <p class="text-sm text-slate-300" id="support-desc">If you enjoy using CineMatch, consider supporting the project! Your donations help keep our servers running and APIs active.</p>
            </div>
            <div class="flex flex-col gap-3 mb-6">
                <a href="https://paypal.me/xicoxyz" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#0070ba] hover:bg-[#003087] text-white py-3 rounded-lg font-bold transition-colors shadow-lg">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M7.076 21.337H2.47a.641.641 0 0 1-.633-.74L4.944.901C5.026.382 5.474 0 5.998 0h7.46c2.57 0 4.578.543 5.69 1.81 1.01 1.15 1.304 2.42 1.012 4.287-.023.143-.047.288-.077.437-.983 5.05-4.349 6.797-8.647 6.797h-2.19c-.524 0-.968.382-1.05.9l-1.12 7.106z"/></svg>
                    <span id="support-btn-paypal">Donate via PayPal</span>
                </a>
                <a href="https://revolut.me/franciq8zz" target="_blank" class="w-full flex items-center justify-center gap-2 bg-[#ffffff] hover:bg-slate-200 text-black py-3 rounded-lg font-bold transition-colors shadow-lg">
                    <span id="support-btn-revolut">Donate via Revolut</span>
                </a>
            </div>
            <div class="border-t border-slate-700/50 pt-5">
                <h3 class="text-lg font-semibold text-pink-400 mb-3" id="support-leaderboard-title">🏆 Top Supporters</h3>
                <div id="leaderboard-list" class="flex flex-col gap-2 max-h-48 overflow-y-auto pr-2 custom-scrollbar">
                    <div class="text-center text-slate-500 text-sm py-4">Loading...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Authentication Modal -->
    <div id="auth-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-overlay p-0 md:p-4">
        <div class="glass-panel p-6 md:p-8 w-full h-full md:h-auto max-w-sm modal-content relative bg-[#0f1115]/95 border-none md:border md:border-slate-700 rounded-none md:rounded-2xl overflow-y-auto">
            <button id="close-modal" class="absolute top-4 right-4 p-3 md:p-2 bg-black/40 md:bg-transparent rounded-full md:rounded-none text-slate-500 hover:text-white text-2xl leading-none w-10 h-10 flex items-center justify-center">&times;</button>
            
            <div class="text-center mb-6">
                <h2 class="text-xl font-bold text-white mb-1" id="modal-title">Join CineMatch</h2>
                <p class="text-sky-400 text-xs font-medium" id="modal-subtitle">You need an account to discover movies.</p>
            </div>

            <div class="flex justify-center mb-5 border-b border-slate-800 pb-0">
                <button id="tab-login" class="text-sm font-semibold px-4 py-2 text-sky-500 border-b-2 border-sky-500 transition-colors">Login</button>
                <button id="tab-register" class="text-sm font-semibold px-4 py-2 text-slate-500 hover:text-slate-300 transition-colors">Register</button>
            </div>
            
            <a href="/api/auth/google" class="flex items-center justify-center gap-3 w-full bg-white hover:bg-slate-100 text-slate-800 font-medium rounded-lg px-4 py-2.5 text-sm transition-all shadow-md mb-4 border border-slate-200">
                <svg class="w-5 h-5" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
                <span id="google-btn-text">Continue with Google</span>
            </a>
            
            <div class="relative flex py-2 items-center mb-4">
                <div class="flex-grow border-t border-slate-700/60"></div>
                <span class="flex-shrink-0 mx-4 text-slate-500 text-[10px] uppercase tracking-widest font-bold" id="lbl-or">or</span>
                <div class="flex-grow border-t border-slate-700/60"></div>
            </div>
            
            <form id="login-form" action="/api/login" method="POST" class="flex flex-col gap-3">
                <input type="text" id="login-user" name="username" placeholder="Username" required autocomplete="username" class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                <input type="password" id="login-pass" name="password" placeholder="Password" required autocomplete="current-password" class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                <div class="text-right mt-1 mb-2">
                    <button type="button" id="forgot-password-link" onclick="openForgotPasswordModal()" class="text-[11px] font-medium text-sky-400 hover:text-sky-300">Esqueceste-te da password?</button>
                </div>
                <button type="submit" class="mt-2 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-all shadow-md w-full">
                    <span id="login-btn-text">Login</span>
                </button>
            </form>
            <form id="register-form" action="/api/register" method="POST" class="flex flex-col gap-3 hidden">
                <input type="text" id="register-user" name="username" placeholder="Username" required autocomplete="username" class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                <input type="password" id="register-pass" name="password" placeholder="Password" required autocomplete="new-password" class="bg-slate-900 border border-slate-700/60 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-1 focus:ring-sky-500 text-white w-full">
                <button type="submit" class="mt-2 bg-sky-600 hover:bg-sky-500 text-white font-medium rounded-lg px-4 py-2.5 text-sm transition-all shadow-md w-full">
                    <span id="register-btn-text">Register</span>
                </button>
            </form>
            <div id="auth-error" class="hidden mt-3 p-2 bg-red-900/30 border border-red-800/50 rounded text-red-300 text-center text-xs"></div>
        </div>
    </div>

    <!-- Trailer Modal -->
    <div id="trailer-modal" class="fixed inset-0 z-50 flex items-center justify-center modal-overlay p-0 md:p-4">
        <div class="glass-panel p-0 md:p-2 w-full max-w-4xl modal-content relative bg-black md:bg-[#0f1115]/95 border-none md:border md:border-slate-700 rounded-none md:rounded-2xl overflow-hidden aspect-video md:aspect-auto">
            <button id="close-trailer-modal" onclick="closeTrailer()" class="absolute top-4 right-4 text-slate-300 hover:text-white text-3xl leading-none z-50 bg-black/60 hover:bg-black/80 rounded-full w-12 h-12 flex items-center justify-center transition-colors">&times;</button>
            <div class="w-full h-full relative z-10" id="trailer-player-container">
                <div id="yt-player-placeholder" class="w-full h-full rounded-lg bg-slate-950"></div>
            </div>
        </div>
    </div>


    
    <!-- Toast Notification -->
    <div id="toast-notification" class="fixed bottom-4 right-4 bg-slate-800 border border-slate-700 text-white px-6 py-3 rounded-lg shadow-xl translate-y-[150%] transition-transform duration-300 z-50 flex items-center gap-3">
        <svg class="w-5 h-5 text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        <span id="toast-message" class="font-medium">Mensagem copiada</span>
    </div>

    <script>
        // Translations
        const AVAILABLE_GENRES = ["Action", "Adventure", "Animation", "Comedy", "Crime", "Documentary", "Drama", "Family", "Fantasy", "History", "Horror", "Music", "Mystery", "Romance", "Sci-Fi", "Thriller", "War", "Western"];
        const dict = {
