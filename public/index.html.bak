                <h3 class="text-xl font-bold text-white" id="dmca-title">Aviso de Direitos (DMCA)</h3>
                <button onclick="closeLegalModal('dmca-modal')" class="text-slate-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <div class="p-6 overflow-y-auto text-sm text-slate-300 leading-relaxed space-y-4 custom-scrollbar" id="dmca-content">
